<Window x:Class="CardGameScorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CardGameScorer"
        xmlns:vm="clr-namespace:CardGameScorer.ViewModels"
        xmlns:conv="clr-namespace:CardGameScorer.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Barbu Scorer" Height="750" Width="1000"
        Icon="Assets/BarbuImage.png"
        WindowState="Maximized"
        Background="#1e1e2e"
        FontSize="{Binding BaseFontSize}"
        PreviewKeyDown="Window_PreviewKeyDown">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:TabSelectedConverter x:Key="TabSelectedConverter"/>
        <conv:TabVisibilityConverter x:Key="TabVisibilityConverter"/>
        <conv:EnumBoolConverter x:Key="EnumBoolConverter"/>
        <conv:BoolToColorConverter x:Key="BoolToColorConverter"/>
        
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#74c7ec"/>
                                <Setter Property="Foreground" Value="#1e1e2e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#45475a"/>
                    <Setter Property="Foreground" Value="#6c7086"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SettingsTabButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="content" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#89b4fa"/>
                                <Setter Property="Foreground" Value="#1e1e2e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary (Cancel/Continue) button: gray bg with light text, dark text on hover -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6c7086"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#9399b2"/>
                                <Setter Property="Foreground" Value="#1e1e2e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsEditButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#585b70"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#89b4fa"/>
                                <Setter Property="Foreground" Value="#1e1e2e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#e6e9ef"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.BaseFontSize}"/>
        </Style>

        <!-- CheckBox: bigger indicator, vertically centered with text -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="box" Width="20" Height="20" CornerRadius="3"
                                    Background="#1e1e2e" BorderBrush="#cdd6f4" BorderThickness="2"
                                    VerticalAlignment="Center">
                                <Path x:Name="check" Stretch="Uniform" Margin="3" Stroke="#a6e3a1" StrokeThickness="2"
                                      Data="M 0 5 L 4 9 L 11 0" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="#a6e3a1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="#89b4fa"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BidCheckBoxStyle: box-only checkbox used in the bidding matrix.
             Has no content slot so it centers cleanly under the Dbl/Re-Dbl labels.
             Has a clearly distinct disabled appearance. -->
        <Style x:Key="BidCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="box" Width="20" Height="20" CornerRadius="3"
                                Background="#1e1e2e" BorderBrush="#cdd6f4" BorderThickness="2">
                            <Path x:Name="check" Stretch="Uniform" Margin="3" Stroke="#a6e3a1" StrokeThickness="2"
                                  Data="M 0 5 L 4 9 L 11 0" Visibility="Collapsed"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="#a6e3a1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="#89b4fa"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="box" Property="Background" Value="#2a2b3a"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="#45475a"/>
                                <Setter TargetName="box" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="20" Height="20" VerticalAlignment="Center">
                                <Ellipse x:Name="outer" Stroke="#cdd6f4" StrokeThickness="2" Fill="#1e1e2e"/>
                                <Ellipse x:Name="dot" Margin="4" Fill="#a6e3a1" Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="outer" Property="Stroke" Value="#a6e3a1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="outer" Property="Stroke" Value="#89b4fa"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.BaseFontSize}"/>
        </Style>
        <Style x:Key="ToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#45475a"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.BaseFontSize}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#6c7086"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5c6bc0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#5c6bc0"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5c6bc0"/>
                                <Setter Property="Foreground" Value="#1e1e2e"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#5c6bc0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#6c7086"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#45475a"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <!-- ==================== PLAYER SETUP SCREEN ==================== -->
        <Grid Visibility="{Binding IsSetupScreen, Converter={StaticResource BoolToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Background="#313244" CornerRadius="15" Padding="40,12,40,18" 
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="500" Margin="20,2">
                <StackPanel Grid.IsSharedSizeScope="True">
                    <Image Source="Assets/BarbuImage.png" Width="200" Height="200" 
                           HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBlock Text="Barbu Scorer" FontSize="{Binding TitleFontSize}" FontWeight="Bold" 
                               Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBlock Text="Enter player names for each position" 
                               Foreground="#a6adc8" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    
                    <!-- Game name input -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="SetupLabel"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Game Name:" FontWeight="SemiBold" 
                                   VerticalAlignment="Center" Foreground="#a6adc8"/>
                        <TextBox Grid.Column="1" Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}" Margin="10,0,0,0"/>
                    </Grid>
                    
                    <!-- Player name inputs -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="SetupLabel"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="West:" FontWeight="SemiBold" 
                                   VerticalAlignment="Center" Foreground="#a6adc8"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WestName, UpdateSourceTrigger=PropertyChanged}" Margin="10,0,0,0"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="North:" FontWeight="SemiBold" 
                                   VerticalAlignment="Center" Foreground="#a6adc8"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NorthName, UpdateSourceTrigger=PropertyChanged}" Margin="10,0,0,0"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="East:" FontWeight="SemiBold" 
                                   VerticalAlignment="Center" Foreground="#a6adc8"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EastName, UpdateSourceTrigger=PropertyChanged}" Margin="10,0,0,0"/>
                        
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="South:" FontWeight="SemiBold" 
                                   VerticalAlignment="Center" Foreground="#a6adc8"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SouthName, UpdateSourceTrigger=PropertyChanged}" Margin="10,0,0,0"/>
                    </Grid>
                    
                    <TextBlock Text="{Binding GameTypeDisplay}" HorizontalAlignment="Center"
                               Foreground="#cdd6f4" FontWeight="SemiBold"
                               FontSize="{Binding LargeFontSize}" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Button Content="Start Game" Command="{Binding StartGameCommand}" 
                                Margin="0,0,15,0"
                                IsEnabled="{Binding CanStartGame}"/>
                        <Button Content="Load Game" Command="{Binding LoadGameCommand}"
                                Background="#6c7086" Margin="0,0,15,0"/>
                        <Button Content="Game Settings" Command="{Binding OpenGameSettingsCommand}"
                                Background="#585b70"/>
                    </StackPanel>
                    
                    <TextBlock Text="First round is West's game. Bidding starts with North (clockwise)." 
                               Foreground="#6c7086" HorizontalAlignment="Center" Margin="0,10,0,0"
                               FontSize="{Binding MediumFontSize}"/>
                </StackPanel>
            </Border>
            </ScrollViewer>
        </Grid>
        
        <!-- ==================== GAME PLAY SCREEN ==================== -->
        <Grid Visibility="{Binding IsGameScreen, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Barbu Scorer" FontSize="{Binding HugeFontSize}" FontWeight="Bold" 
                               Foreground="#cdd6f4" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <!-- Settings Gear Button -->
                <Grid Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Command="{Binding ToggleSettingsMenuCommand}" 
                            BorderThickness="0"
                            Padding="10" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="5">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#5c6bc0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="⚙" FontSize="24" Foreground="#cdd6f4"/>
                    </Button>
                    
                    <!-- Settings Popup Menu -->
                    <Popup IsOpen="{Binding IsSettingsMenuOpen}" 
                           PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Button}}"
                           Placement="Bottom" StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="#313244" CornerRadius="8" Padding="5" 
                                BorderBrush="#45475a" BorderThickness="1">
                            <StackPanel MinWidth="150">
                                <Button Content="Save Game" Command="{Binding SaveGameCommand}"
                                        HorizontalContentAlignment="Left" Padding="10,8"
                                        BorderThickness="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#cdd6f4"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#89b4fa"/>
                                                    <Setter Property="Foreground" Value="#1e1e2e"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Save As…" Command="{Binding SaveGameAsCommand}"
                                        HorizontalContentAlignment="Left" Padding="10,8"
                                        BorderThickness="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#cdd6f4"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#89b4fa"/>
                                                    <Setter Property="Foreground" Value="#1e1e2e"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Load Game" Command="{Binding LoadGameCommand}"
                                        HorizontalContentAlignment="Left" Padding="10,8"
                                        BorderThickness="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#cdd6f4"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#89b4fa"/>
                                                    <Setter Property="Foreground" Value="#1e1e2e"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Border Height="1" Background="#45475a" Margin="5,3"/>
                                <Button Content="New Game" Command="{Binding NewGameCommand}"
                                        HorizontalContentAlignment="Left" Padding="10,8"
                                        BorderThickness="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#f38ba8"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#89b4fa"/>
                                                    <Setter Property="Foreground" Value="#a63d56"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Border Height="1" Background="#45475a" Margin="5,3"/>
                                <Button Content="Game Settings" Command="{Binding OpenGameSettingsCommand}"
                                        HorizontalContentAlignment="Left" Padding="10,8"
                                        BorderThickness="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#cdd6f4"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#89b4fa"/>
                                                    <Setter Property="Foreground" Value="#1e1e2e"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="How To Play" Command="{Binding OpenHowToPlayCommand}"
                                        HorizontalContentAlignment="Left" Padding="10,8"
                                        BorderThickness="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#cdd6f4"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#89b4fa"/>
                                                    <Setter Property="Foreground" Value="#1e1e2e"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
            
            <!-- Tab Control -->
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                        SelectedIndex="{Binding SelectedMainTab, Mode=TwoWay}"
                        Visibility="{Binding IsSettingsOpen, Converter={StaticResource InverseBoolToVis}}">
                <TabControl.Style>
                    <Style TargetType="TabControl">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TabPanel Grid.Row="0" IsItemsHost="True" HorizontalAlignment="Center"/>
                                        <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Style>
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="#313244"/>
                        <Setter Property="Foreground" Value="#cdd6f4"/>
                        <Setter Property="Padding" Value="20,10"/>
                        <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.BaseFontSize}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                            CornerRadius="8,8,0,0" Padding="{TemplateBinding Padding}" Margin="0,0,5,0">
                                        <ContentPresenter ContentSource="Header"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#89b4fa"/>
                                            <Setter Property="Foreground" Value="#1e1e2e"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#45475a"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="True"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Border" Property="Background" Value="#89b4fa"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                
                <!-- ==================== TAB 1: CURRENT GAME ==================== -->
                <TabItem Header="Current Game">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Border Background="#1e1e2e" Padding="0,15,0,0" HorizontalAlignment="Center">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Status Message (hidden — game name shows in panel header) -->
                            <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" Foreground="#a6adc8" 
                                       TextWrapping="Wrap" Margin="0,0,0,15" Visibility="Collapsed"/>
                            
                            <!-- Main Content -->
                            <Grid Grid.Row="1">
                
                <!-- Game Flow Panel -->
                <Border Background="#313244" CornerRadius="10" Padding="20"
                        HorizontalAlignment="Center"
                        Visibility="{Binding IsGameComplete, Converter={StaticResource InverseBoolToVis}}"
                        MaxWidth="{Binding GameFlowMaxWidth}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Top-right Back button (shared across phases) -->
                        <Button Grid.Row="0" Grid.RowSpan="3" Content="Back"
                                Command="{Binding BackCommand}"
                                Background="#6c7086" Foreground="#cdd6f4"
                                Padding="12,4" FontWeight="SemiBold"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Panel.ZIndex="10"
                                Visibility="{Binding IsSelectingContract, Converter={StaticResource InverseBoolToVis}}"/>
                        
                        <!-- Phase: Selecting Contract -->
                        <StackPanel Grid.Row="0" Grid.RowSpan="2"
                                    Visibility="{Binding IsSelectingContract, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="{Binding XLargeFontSize}" Foreground="#cdd6f4" Margin="0,0,0,20">
                                <Run Text="{Binding DealerNamePossessive, Mode=OneWay}" FontWeight="Bold"/>
                                <Run Text="{Binding DealerTurnSuffix, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                            
                            <TextBlock Text="Select a game:" Margin="0,0,0,12"/>
                            
                            <ItemsControl ItemsSource="{Binding AllContractOptions}" Grid.IsSharedSizeScope="True">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,5" Padding="10,8" CornerRadius="6">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#313244"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#45475a"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="140" SharedSizeGroup="ContractNameCol"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Clickable Game Name -->
                                                <Button Grid.Column="0"
                                                        Command="{Binding DataContext.SelectContractCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding IsAvailable}"
                                                        HorizontalContentAlignment="Left" Padding="0"
                                                        Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <ContentPresenter/>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#89b4fa"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                        <Setter Property="Foreground" Value="#6c7086"/>
                                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Foreground" Value="#a6e3a1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Button>
                                                
                                                <!-- Description -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding Description}" 
                                                               FontSize="{Binding DataContext.MediumFontSize, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#a6adc8"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                        <Setter Property="Foreground" Value="#6c7086"/>
                                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Info icon for Fan Tan: explains where to change scoring/name -->
                                                    <Grid Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Type}" Value="FanTan">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <ToggleButton x:Name="FanTanInfoToggle"
                                                                      Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                                      ToolTip="About Fan Tan">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                            <Border Background="#89b4fa" CornerRadius="999"
                                                                    Width="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    Height="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                <TextBlock Text="i" Foreground="#1e1e2e" FontWeight="Bold" FontStyle="Italic"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                            </Border>
                                                        </ToggleButton>
                                                        <Popup PlacementTarget="{Binding ElementName=FanTanInfoToggle}" Placement="Bottom"
                                                               IsOpen="{Binding IsChecked, ElementName=FanTanInfoToggle}"
                                                               StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                                            <Border Background="#1e1e2e" BorderBrush="#89b4fa" BorderThickness="1" CornerRadius="6"
                                                                    Padding="12" MaxWidth="320" Margin="0,4,0,0">
                                                                <Border.Effect>
                                                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                                                </Border.Effect>
                                                                <TextBlock Foreground="#cdd6f4" TextWrapping="Wrap"
                                                                           FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                           Text="Name and scoring can be modified in Settings &gt; Game Variants."/>
                                                            </Border>
                                                        </Popup>
                                                    </Grid>
                                                </StackPanel>
                                                
                                                <!-- Selected Indicator -->
                                                <TextBlock Grid.Column="2" Text="✓" FontSize="{Binding DataContext.LargeFontSize, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="Bold"
                                                           Foreground="#a6e3a1" VerticalAlignment="Center" Margin="10,0,0,0"
                                                           Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        
                        <!-- Phase: Bidding (Single-View Doubling Matrix) -->
                        <StackPanel Grid.Row="0" Grid.RowSpan="2"
                                    Grid.IsSharedSizeScope="True"
                                    Visibility="{Binding IsBidding, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Bidding: Doubles &amp; Redoubles"
                                       FontSize="{Binding XLargeFontSize}"
                                       FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,15"/>

                            <!-- Header row: empty corner cell, then one column per player, then spacer for Max button -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="BidLabel"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="BidMax"/>
                                </Grid.ColumnDefinitions>
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding DoublingMatrixHeaders}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1f3a5f" Margin="6,0" Padding="8,10">
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="White" FontWeight="Bold"
                                                           FontSize="{Binding DataContext.LargeFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           HorizontalAlignment="Stretch"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Label}"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <!-- Matrix rows -->
                            <ItemsControl ItemsSource="{Binding DoublingMatrix}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="BidLabel"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="BidMax"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Row label -->
                                            <Border Grid.Column="0" Background="#313244" Padding="10,12" Margin="0,0,2,0">
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DoublerLabel}"
                                                               Foreground="#cdd6f4"
                                                               FontWeight="SemiBold"
                                                               FontSize="{Binding DataContext.LargeFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    <Border Background="#1f3a5f" CornerRadius="4" Padding="6,2"
                                                            HorizontalAlignment="Left" Margin="0,4,0,0"
                                                            Visibility="{Binding IsDealer, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="Dealer" Foreground="White" FontWeight="Bold"
                                                                   FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    </Border>
                                                </StackPanel>
                                            </Border>

                                            <!-- Cells -->
                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#3a3a52" Margin="6,0" Padding="6,8">
                                                            <Grid>
                                                                <!-- Empty diagonal cell -->
                                                                <TextBlock Text="—"
                                                                           Foreground="#585b70"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="{Binding DataContext.LargeFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>
                                                                <StackPanel Orientation="Horizontal"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Visibility="{Binding IsNotEmpty, Converter={StaticResource BoolToVis}}">
                                                                    <StackPanel Orientation="Vertical" VerticalAlignment="Top" Margin="0,0,18,0"
                                                                                Visibility="{Binding IsDoubleVisible, Converter={StaticResource BoolToVis}}">
                                                                        <CheckBox Style="{StaticResource BidCheckBoxStyle}"
                                                                                  IsChecked="{Binding IsDouble, Mode=TwoWay}"
                                                                                  IsEnabled="{Binding IsDoubleEnabled}"
                                                                                  Click="MandatoryDouble_Click"
                                                                                  ToolTip="Double">
                                                                            <CheckBox.LayoutTransform>
                                                                                <ScaleTransform ScaleX="2.2" ScaleY="2.2"/>
                                                                            </CheckBox.LayoutTransform>
                                                                        </CheckBox>
                                                                        <TextBlock Text="Dbl"
                                                                                   FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                   HorizontalAlignment="Center"
                                                                                   Margin="0,4,0,0">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#a6adc8"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsDoubleEnabled}" Value="False">
                                                                                            <Setter Property="Foreground" Value="#585b70"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                                                                        <CheckBox Style="{StaticResource BidCheckBoxStyle}"
                                                                                  IsChecked="{Binding EffectiveRedouble, Mode=TwoWay}"
                                                                                  IsEnabled="{Binding IsRedoubleEnabled}"
                                                                                  ToolTip="Redouble (enabled after Dbl is checked)">
                                                                            <CheckBox.LayoutTransform>
                                                                                <ScaleTransform ScaleX="2.2" ScaleY="2.2"/>
                                                                            </CheckBox.LayoutTransform>
                                                                        </CheckBox>
                                                                        <TextBlock Text="Re-Dbl"
                                                                                   FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                   HorizontalAlignment="Center"
                                                                                   Margin="0,4,0,0">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#a6adc8"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsRedoubleEnabled}" Value="False">
                                                                                            <Setter Property="Foreground" Value="#585b70"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Dealer-locked message (shown instead of cells when dealer can't double) -->
                                            <Border Grid.Column="1" Background="Transparent" Margin="6,0" Padding="0"
                                                    Visibility="Collapsed">
                                            </Border>

                                            <!-- Max button outside the table -->
                                            <Button Grid.Column="2" Content="Max"
                                                    Command="{Binding MaxCommand}"
                                                    Background="#fab387" Foreground="#1e1e2e"
                                                    FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Margin="8,0,0,0"
                                                    Padding="14,8"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    Visibility="{Binding IsNotDealerLocked, Converter={StaticResource BoolToVis}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,20">
                                <Button Content="Confirm Bidding" Command="{Binding ConfirmBiddingMatrixCommand}"
                                        Background="#a6e3a1" Foreground="#1e1e2e"
                                        Padding="25,10" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                        
                        
                        <!-- Phase: Entering Scores -->
                        <StackPanel Grid.Row="0" Grid.RowSpan="2"
                                    Visibility="{Binding IsEnteringScores, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding SelectedContractName, Mode=OneWay}"
                                       FontSize="{Binding XLargeFontSize}" FontWeight="SemiBold"
                                       Margin="0,0,0,15" Foreground="#a6e3a1"
                                       HorizontalAlignment="Center"/>
                            
                            <!-- Ace of Hearts dropdown (only for Hearts contract) -->
                            <StackPanel Visibility="{Binding IsHeartsContract, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,15">
                                <StackPanel Visibility="{Binding NotSaladeMode, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Player who won the Ace of Hearts:" FontWeight="SemiBold" 
                                               Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding Players}" 
                                              SelectedItem="{Binding AceOfHeartsPlayer}"
                                              DisplayMemberPath="DisplayName"
                                              MinWidth="260" HorizontalAlignment="Left"
                                              Background="#e6e9ef"
                                              Foreground="#1e1e2e"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- King of Hearts dropdown (only for Barbu contract) -->
                            <StackPanel Visibility="{Binding IsBarbuContract, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,15">
                                <TextBlock Text="Select who took the King of Hearts" FontSize="{Binding LargeFontSize}" 
                                           FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,15" TextWrapping="Wrap"/>
                                <TextBlock Text="Player who won the King of Hearts:" FontWeight="SemiBold" 
                                           Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Players}" 
                                          SelectedItem="{Binding KingOfHeartsPlayer}"
                                          DisplayMemberPath="DisplayName"
                                          MinWidth="260" HorizontalAlignment="Left"
                                          Background="#e6e9ef"
                                          Foreground="#1e1e2e"/>
                            </StackPanel>
                            
                            <!-- No Last Two dropdowns -->
                            <StackPanel Visibility="{Binding IsNoLastTwoContract, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,15">
                                <TextBlock Text="Select who won the last two tricks" FontSize="{Binding LargeFontSize}" 
                                           FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,15" TextWrapping="Wrap"
                                           Visibility="{Binding NotSaladeMode, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="Select who won the last trick" FontSize="{Binding LargeFontSize}" 
                                           FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,15" TextWrapping="Wrap"
                                           Visibility="{Binding IsSaladeMode, Converter={StaticResource BoolToVis}}"/>
                                <StackPanel Visibility="{Binding NotSaladeMode, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Player who won the 2nd to last trick:" FontWeight="SemiBold" 
                                               Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding Players}" 
                                              SelectedItem="{Binding SecondToLastTrickPlayer}"
                                              DisplayMemberPath="DisplayName"
                                              MinWidth="260" HorizontalAlignment="Left"
                                              Background="#e6e9ef"
                                              Foreground="#1e1e2e"
                                              Margin="0,0,0,10"/>
                                </StackPanel>
                                <TextBlock Text="Player who won the last trick:" FontWeight="SemiBold" 
                                           Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Players}" 
                                          SelectedItem="{Binding LastTrickPlayer}"
                                          DisplayMemberPath="DisplayName"
                                          MinWidth="260" HorizontalAlignment="Left"
                                          Background="#e6e9ef"
                                          Foreground="#1e1e2e"/>
                            </StackPanel>
                            
                            <!-- Ravage City player selection (checkboxes for ties) -->
                            <StackPanel Visibility="{Binding IsRavageCityContract, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,15">
                                <TextBlock Text="Select the player(s) who took the most cards in any suit" 
                                           FontSize="{Binding LargeFontSize}" 
                                           FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,15" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding RavageCityScoringDescription}" 
                                           Foreground="#6c7086" Margin="0,0,0,10" FontStyle="Italic"/>
                                <ItemsControl ItemsSource="{Binding RavageCityPlayerSelections}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                                      Margin="0,5,0,5">
                                                <TextBlock Text="{Binding Player.DisplayName}" FontSize="{Binding DataContext.MediumFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            
                            <!-- Chinese Poker scoring input -->
                            <StackPanel Visibility="{Binding IsChinesePokerContract, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,15">
                                <TextBlock Text="Enter Chinese Poker beats (+4 points per beat)" 
                                           FontSize="{Binding LargeFontSize}" 
                                           FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,15" TextWrapping="Wrap"/>
                                
                                <!-- Scoring mode radio buttons -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <RadioButton x:Name="ScoreBySettingRadio" 
                                                 Content="Score by Setting (Front/Middle/Back)" 
                                                 IsChecked="{Binding ChinesePokerScoreBySetting, Mode=TwoWay}"
                                                 Margin="0,0,20,0" VerticalContentAlignment="Center"/>
                                    <RadioButton x:Name="ScoreByTotalRadio" 
                                                 Content="Score by Total Beats" 
                                                 IsChecked="{Binding ChinesePokerScoreByTotalBeats, Mode=TwoWay}"
                                                 VerticalContentAlignment="Center"/>
                                </StackPanel>
                                
                                <!-- Score by Setting mode: 4 players × 3 columns (Front/Middle/Back) -->
                                <Grid Visibility="{Binding ChinesePokerScoreBySetting, Converter={StaticResource BoolToVis}}" 
                                      KeyboardNavigation.TabNavigation="Local"
                                      Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                                        <ColumnDefinition Width="Auto" MinWidth="90"/>
                                        <ColumnDefinition Width="Auto" MinWidth="90"/>
                                        <ColumnDefinition Width="Auto" MinWidth="90"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Headers -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Player" FontWeight="Bold" Margin="0,0,10,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Front" FontWeight="Bold" HorizontalAlignment="Center" Margin="12,0,12,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Middle" FontWeight="Bold" HorizontalAlignment="Center" Margin="12,0,12,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Back" FontWeight="Bold" HorizontalAlignment="Center" Margin="12,0,12,5"/>
                                    
                                    <!-- Player 1 -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Players[0].DisplayName}" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="CPSetting00" Tag="0,0" TabIndex="1" Width="60" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="CPSetting01" Tag="0,1" TabIndex="5" Width="60" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" x:Name="CPSetting02" Tag="0,2" TabIndex="9" Width="60" TextAlignment="Center" Margin="5,2"/>
                                    
                                    <!-- Player 2 -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Players[1].DisplayName}" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="CPSetting10" Tag="1,0" TabIndex="2" Width="60" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="2" Grid.Column="2" x:Name="CPSetting11" Tag="1,1" TabIndex="6" Width="60" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="2" Grid.Column="3" x:Name="CPSetting12" Tag="1,2" TabIndex="10" Width="60" TextAlignment="Center" Margin="5,2"/>
                                    
                                    <!-- Player 3 -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding Players[2].DisplayName}" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="CPSetting20" Tag="2,0" TabIndex="3" Width="60" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="3" Grid.Column="2" x:Name="CPSetting21" Tag="2,1" TabIndex="7" Width="60" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="3" Grid.Column="3" x:Name="CPSetting22" Tag="2,2" TabIndex="11" Width="60" TextAlignment="Center" Margin="5,2"/>
                                    
                                    <!-- Player 4 -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding Players[3].DisplayName}" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="CPSetting30" Tag="3,0" TabIndex="4" Width="60" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="4" Grid.Column="2" x:Name="CPSetting31" Tag="3,1" TabIndex="8" Width="60" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="4" Grid.Column="3" x:Name="CPSetting32" Tag="3,2" TabIndex="12" Width="60" TextAlignment="Center" Margin="5,2"/>
                                </Grid>
                                <TextBlock Visibility="{Binding ChinesePokerScoreBySetting, Converter={StaticResource BoolToVis}}"
                                           Text="Each column (Front/Middle/Back) must sum to 6 beats" 
                                           Foreground="#6c7086" FontStyle="Italic" Margin="0,0,0,10"/>
                                
                                <!-- Score by Total Beats mode: 4 players × 1 column -->
                                <Grid Visibility="{Binding ChinesePokerScoreByTotalBeats, Converter={StaticResource BoolToVis}}" 
                                      Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="15"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="{Binding Players[0].DisplayName}" FontWeight="SemiBold"/>
                                        <TextBox x:Name="CPTotal0" Tag="T0" Width="80" TextAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Text="{Binding Players[1].DisplayName}" FontWeight="SemiBold"/>
                                        <TextBox x:Name="CPTotal1" Tag="T1" Width="80" TextAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <TextBlock Text="{Binding Players[2].DisplayName}" FontWeight="SemiBold"/>
                                        <TextBox x:Name="CPTotal2" Tag="T2" Width="80" TextAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="2">
                                        <TextBlock Text="{Binding Players[3].DisplayName}" FontWeight="SemiBold"/>
                                        <TextBox x:Name="CPTotal3" Tag="T3" Width="80" TextAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Visibility="{Binding ChinesePokerScoreByTotalBeats, Converter={StaticResource BoolToVis}}"
                                           Text="Total beats across all players must equal 18" 
                                           Foreground="#6c7086" FontStyle="Italic" Margin="0,0,0,10"/>
                            </StackPanel>
                            
                            <!-- Salade combined input panel -->
                            <StackPanel Visibility="{Binding IsSaladeContract, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,15">
                                <TextBlock Text="Salade: enter tricks, queens, and hearts per player"
                                           FontSize="{Binding LargeFontSize}"
                                           FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,15" TextWrapping="Wrap"/>
                                <Grid Margin="0,0,0,10" KeyboardNavigation.TabNavigation="Local">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Player" FontWeight="Bold" Margin="0,0,10,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Tricks" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Queens" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Hearts" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Players[0].DisplayName}" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="SaladeTricks0" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="1"/>
                                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="SaladeQueens0" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="5"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" x:Name="SaladeHearts0" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="9"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Players[1].DisplayName}" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="SaladeTricks1" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="2"/>
                                    <TextBox Grid.Row="2" Grid.Column="2" x:Name="SaladeQueens1" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="6"/>
                                    <TextBox Grid.Row="2" Grid.Column="3" x:Name="SaladeHearts1" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="10"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding Players[2].DisplayName}" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="SaladeTricks2" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="3"/>
                                    <TextBox Grid.Row="3" Grid.Column="2" x:Name="SaladeQueens2" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="7"/>
                                    <TextBox Grid.Row="3" Grid.Column="3" x:Name="SaladeHearts2" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="11"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding Players[3].DisplayName}" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="SaladeTricks3" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="4"/>
                                    <TextBox Grid.Row="4" Grid.Column="2" x:Name="SaladeQueens3" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="8"/>
                                    <TextBox Grid.Row="4" Grid.Column="3" x:Name="SaladeHearts3" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="12"/>
                                </Grid>
                                <TextBlock Text="Tricks must total 13, queens 4, hearts 13."
                                           Foreground="#6c7086" FontStyle="Italic" Margin="0,0,0,10"/>
                                <TextBlock Text="Player who won the last trick:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Players}"
                                          SelectedItem="{Binding LastTrickPlayer}"
                                          DisplayMemberPath="DisplayName"
                                          MinWidth="260" HorizontalAlignment="Left"
                                          Background="#e6e9ef" Foreground="#1e1e2e" Margin="0,0,0,10"/>
                                <TextBlock Text="Player who won the King of Hearts:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Players}"
                                          SelectedItem="{Binding KingOfHeartsPlayer}"
                                          DisplayMemberPath="DisplayName"
                                          MinWidth="260" HorizontalAlignment="Left"
                                          Background="#e6e9ef" Foreground="#1e1e2e"/>
                            </StackPanel>

                            <!-- Score inputs (hidden for Barbu which only uses dropdown) -->
                            <StackPanel Visibility="{Binding ShowScoreInputs, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ContractInstructions}" FontSize="{Binding LargeFontSize}" 
                                       FontWeight="Bold" Foreground="#228B22" Margin="0,0,0,15" TextWrapping="Wrap"/>
                            
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="15"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="{Binding Players[0].DisplayName}" FontWeight="SemiBold"/>
                                    <TextBox x:Name="ScoreInput0" Tag="0"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="{Binding Players[1].DisplayName}" FontWeight="SemiBold"/>
                                    <TextBox x:Name="ScoreInput1" Tag="1"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="{Binding Players[2].DisplayName}" FontWeight="SemiBold"/>
                                    <TextBox x:Name="ScoreInput2" Tag="2"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="{Binding Players[3].DisplayName}" FontWeight="SemiBold"/>
                                    <TextBox x:Name="ScoreInput3" Tag="3"/>
                                </StackPanel>
                            </Grid>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                <Button Content="Submit Score" Click="RecordHand_Click" 
                                        Background="#a6e3a1" x:Name="SubmitScoreButton"/>
                                <!-- Error popup floats below the Submit Score button so layout never shifts; auto-dismisses after 5s. -->
                                <Popup IsOpen="{Binding HasError, Mode=OneWay}"
                                       PlacementTarget="{Binding ElementName=SubmitScoreButton}"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       StaysOpen="True"
                                       HorizontalOffset="-100"
                                       VerticalOffset="8">
                                    <Border Background="#f38ba8" CornerRadius="5" Padding="12" MaxWidth="700">
                                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#1e1e2e"
                                                   TextWrapping="Wrap" FontWeight="SemiBold"/>
                                    </Border>
                                </Popup>
                            </StackPanel>
                            
                            <!-- Doubles Summary -->
                            <Border Background="#45475a" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Doubles for this round:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <ToggleButton Grid.Column="1" x:Name="DoublesToggle"
                                                      Background="#89b4fa" Foreground="#1e1e2e"
                                                      BorderThickness="0" Padding="12,4" Cursor="Hand">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton">
                                                    <Setter Property="Content" Value="Show"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Content" Value="Hide"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                        </ToggleButton>
                                    </Grid>
                                    <StackPanel Margin="0,10,0,0"
                                                Visibility="{Binding IsChecked, ElementName=DoublesToggle, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl ItemsSource="{Binding BiddingState.Doubles}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Vertical" Margin="0,2,0,2">
                                                        <TextBlock Foreground="#cdd6f4"><Run Text="{Binding Doubler.Name, Mode=OneWay}"/><Run Text=" doubled "/><Run Text="{Binding Target.Name, Mode=OneWay}"/></TextBlock>
                                                        <TextBlock Foreground="#a6adc8" Margin="15,2,0,0"
                                                                   Visibility="{Binding IsRedoubled, Converter={StaticResource BoolToVis}}"><Run Text="{Binding Target.Name, Mode=OneWay}"/><Run Text=" redoubled "/><Run Text="{Binding Doubler.Name, Mode=OneWay}"/></TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="No doubles" Foreground="#6c7086" 
                                                   Visibility="{Binding BiddingState.HasNoDoubles, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <!-- Phase: Score Summary -->
                        <StackPanel Grid.Row="0" Grid.RowSpan="2"
                                    Visibility="{Binding IsScoreSummary, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Score Summary" FontSize="{Binding XLargeFontSize}" FontWeight="SemiBold" 
                                       Foreground="#cdd6f4" Margin="0,0,0,15"/>

                            <!-- Auto-skip note: shown only when bidding produced no doubles on a negative contract -->
                            <Border Background="#1e2436" BorderBrush="#89b4fa" BorderThickness="1" CornerRadius="6"
                                    Padding="14,10" Margin="0,0,0,15"
                                    Visibility="{Binding IsBiddingSkippedScoreEntry, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="No doubles. Round is skipped and points are divided among non-dealers as evenly as possible."
                                               Foreground="#cdd6f4" FontSize="{Binding BaseFontSize}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <ToggleButton x:Name="SkipNoDoublesInfoToggle" Margin="8,0,0,0" VerticalAlignment="Center"
                                                  Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                  ToolTip="More info">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                        <Border Background="#89b4fa" CornerRadius="999"
                                                Width="{Binding BaseFontSize}" Height="{Binding BaseFontSize}">
                                            <TextBlock Text="i" Foreground="#1e1e2e" FontWeight="Bold" FontStyle="Italic"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontSize="{Binding SmallFontSize}"/>
                                        </Border>
                                    </ToggleButton>
                                    <Popup PlacementTarget="{Binding ElementName=SkipNoDoublesInfoToggle}" Placement="Bottom"
                                           IsOpen="{Binding IsChecked, ElementName=SkipNoDoublesInfoToggle}"
                                           StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border Background="#1e1e2e" BorderBrush="#89b4fa" BorderThickness="1" CornerRadius="6"
                                                Padding="12" MaxWidth="360" Margin="0,4,0,0">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                            </Border.Effect>
                                            <TextBlock Foreground="#cdd6f4" TextWrapping="Wrap"
                                                       FontSize="{Binding BaseFontSize}"
                                                       Text="This can be disabled in Game Settings &gt; Optional Rules"/>
                                        </Border>
                                    </Popup>
                                </StackPanel>
                            </Border>
                            
                            <!-- Player Score Tiles - 4 in a row, collapsing to 2x2 (W/N top, E/S bottom) -->
                            <UniformGrid Columns="4" Margin="0,0,0,15" x:Name="ScoreTilesGrid">
                                <!-- Player 1 (West) Tile -->
                                <Border Background="#313244" CornerRadius="10" Padding="20" Margin="0,0,10,10" MinWidth="140">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Players[0].Name}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4"/>
                                        <StackPanel Margin="0,10,0,0"
                                                    Visibility="{Binding IsScoreSummaryNotSkipped, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Before Doubles" FontSize="{Binding SmallFontSize}" Foreground="#6c7086"/>
                                            <TextBlock Text="{Binding SummaryBaseScores[0]}" FontSize="{Binding XXLargeFontSize}" Foreground="#a6adc8"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,10,0,0">
                                            <TextBlock Text="Final Score" FontSize="{Binding SmallFontSize}" Foreground="#a6e3a1"/>
                                            <TextBlock Text="{Binding SummaryFinalScores[0]}" FontSize="{Binding HugeFontSize}" FontWeight="Bold" Foreground="#a6e3a1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Player 2 (North) Tile -->
                                <Border Background="#313244" CornerRadius="10" Padding="20" Margin="0,0,10,10" MinWidth="140">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Players[1].Name}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4"/>
                                        <StackPanel Margin="0,10,0,0"
                                                    Visibility="{Binding IsScoreSummaryNotSkipped, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Before Doubles" FontSize="{Binding SmallFontSize}" Foreground="#6c7086"/>
                                            <TextBlock Text="{Binding SummaryBaseScores[1]}" FontSize="{Binding XXLargeFontSize}" Foreground="#a6adc8"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,10,0,0">
                                            <TextBlock Text="Final Score" FontSize="{Binding SmallFontSize}" Foreground="#a6e3a1"/>
                                            <TextBlock Text="{Binding SummaryFinalScores[1]}" FontSize="{Binding HugeFontSize}" FontWeight="Bold" Foreground="#a6e3a1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Player 3 (East) Tile -->
                                <Border Background="#313244" CornerRadius="10" Padding="20" Margin="0,0,10,10" MinWidth="140">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Players[2].Name}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4"/>
                                        <StackPanel Margin="0,10,0,0"
                                                    Visibility="{Binding IsScoreSummaryNotSkipped, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Before Doubles" FontSize="{Binding SmallFontSize}" Foreground="#6c7086"/>
                                            <TextBlock Text="{Binding SummaryBaseScores[2]}" FontSize="{Binding XXLargeFontSize}" Foreground="#a6adc8"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,10,0,0">
                                            <TextBlock Text="Final Score" FontSize="{Binding SmallFontSize}" Foreground="#a6e3a1"/>
                                            <TextBlock Text="{Binding SummaryFinalScores[2]}" FontSize="{Binding HugeFontSize}" FontWeight="Bold" Foreground="#a6e3a1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Player 4 (South) Tile -->
                                <Border Background="#313244" CornerRadius="10" Padding="20" Margin="0,0,10,10" MinWidth="140">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Players[3].Name}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4"/>
                                        <StackPanel Margin="0,10,0,0"
                                                    Visibility="{Binding IsScoreSummaryNotSkipped, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Before Doubles" FontSize="{Binding SmallFontSize}" Foreground="#6c7086"/>
                                            <TextBlock Text="{Binding SummaryBaseScores[3]}" FontSize="{Binding XXLargeFontSize}" Foreground="#a6adc8"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,10,0,0">
                                            <TextBlock Text="Final Score" FontSize="{Binding SmallFontSize}" Foreground="#a6e3a1"/>
                                            <TextBlock Text="{Binding SummaryFinalScores[3]}" FontSize="{Binding HugeFontSize}" FontWeight="Bold" Foreground="#a6e3a1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            
                            <!-- Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Confirm Scores" Command="{Binding ConfirmSummaryCommand}"
                                        Background="#a6e3a1"/>
                            </StackPanel>
                        </StackPanel>
                        
                    </Grid>
                </Border>

                <!-- Game Over: Podium -->
                <Border Background="#313244" CornerRadius="10" Padding="30,28"
                        HorizontalAlignment="Center"
                        Visibility="{Binding IsGameComplete, Converter={StaticResource BoolToVis}}"
                        MaxWidth="{Binding GameFlowMaxWidth}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🏆 Game Over 🏆" FontWeight="Bold" Foreground="#f9e2af"
                                   FontSize="{Binding HugeFontSize}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Final Standings" Foreground="#a6adc8"
                                   FontSize="{Binding LargeFontSize}" HorizontalAlignment="Center" Margin="0,0,0,28"/>

                        <!-- Podium row: silver(2nd) | gold(1st) | bronze(3rd) -->
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 2nd place (left) -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Margin="10,0">
                                <!-- Silver medal -->
                                <Grid Width="70" Height="86" HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <!-- Ribbons -->
                                    <Polygon Points="10,0 28,0 22,46 14,46" Fill="#89b4fa"/>
                                    <Polygon Points="42,0 60,0 56,46 48,46" Fill="#89b4fa"/>
                                    <!-- Medal disc -->
                                    <Ellipse Width="56" Height="56" Fill="#bac2de" Stroke="#9399b2" StrokeThickness="2"
                                             VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                    <Ellipse Width="42" Height="42" Fill="#cdd6f4" Stroke="#9399b2" StrokeThickness="1"
                                             VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,7"/>
                                    <TextBlock Text="2" Foreground="#1e1e2e" FontWeight="Bold" FontSize="22"
                                               VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                </Grid>
                                <TextBlock Text="{Binding PodiumEntries[1].Name}" Foreground="#cdd6f4" FontWeight="Bold"
                                           FontSize="{Binding XLargeFontSize}" HorizontalAlignment="Center"/>
                                <TextBlock Foreground="#bac2de" FontWeight="SemiBold"
                                           FontSize="{Binding LargeFontSize}" HorizontalAlignment="Center" Margin="0,2,0,8">
                                    <Run Text="{Binding PodiumEntries[1].Score, Mode=OneWay}"/><Run Text=" pts"/>
                                </TextBlock>
                                <Border Background="#bac2de" CornerRadius="4,4,0,0" Width="150"
                                        Height="{Binding PodiumEntries[1].BlockHeight}">
                                    <TextBlock Text="2nd" Foreground="#1e1e2e" FontWeight="Bold" FontSize="40"
                                               HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0"/>
                                </Border>
                            </StackPanel>

                            <!-- 1st place (center) -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="10,0">
                                <!-- Gold medal -->
                                <Grid Width="86" Height="106" HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <Polygon Points="14,0 36,0 28,58 18,58" Fill="#f38ba8"/>
                                    <Polygon Points="50,0 72,0 68,58 58,58" Fill="#f38ba8"/>
                                    <Ellipse Width="70" Height="70" Fill="#f9e2af" Stroke="#fab387" StrokeThickness="2"
                                             VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                    <Ellipse Width="54" Height="54" Fill="#f5d97a" Stroke="#fab387" StrokeThickness="1"
                                             VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="1" Foreground="#1e1e2e" FontWeight="Bold" FontSize="28"
                                               VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                                </Grid>
                                <TextBlock Text="{Binding PodiumEntries[0].Name}" Foreground="#f9e2af" FontWeight="Bold"
                                           FontSize="{Binding HugeFontSize}" HorizontalAlignment="Center"/>
                                <TextBlock Foreground="#f9e2af" FontWeight="SemiBold"
                                           FontSize="{Binding XLargeFontSize}" HorizontalAlignment="Center" Margin="0,2,0,8">
                                    <Run Text="{Binding PodiumEntries[0].Score, Mode=OneWay}"/><Run Text=" pts"/>
                                </TextBlock>
                                <Border Background="#f9e2af" CornerRadius="4,4,0,0" Width="170"
                                        Height="{Binding PodiumEntries[0].BlockHeight}">
                                    <TextBlock Text="1st" Foreground="#1e1e2e" FontWeight="Bold" FontSize="52"
                                               HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0"/>
                                </Border>
                            </StackPanel>

                            <!-- 3rd place (right) -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="10,0">
                                <!-- Bronze medal -->
                                <Grid Width="60" Height="76" HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <Polygon Points="8,0 24,0 18,40 12,40" Fill="#a6e3a1"/>
                                    <Polygon Points="36,0 52,0 48,40 40,40" Fill="#a6e3a1"/>
                                    <Ellipse Width="48" Height="48" Fill="#fab387" Stroke="#cb6f3a" StrokeThickness="2"
                                             VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                    <Ellipse Width="36" Height="36" Fill="#e8a47a" Stroke="#cb6f3a" StrokeThickness="1"
                                             VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="3" Foreground="#1e1e2e" FontWeight="Bold" FontSize="20"
                                               VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                                </Grid>
                                <TextBlock Text="{Binding PodiumEntries[2].Name}" Foreground="#fab387" FontWeight="Bold"
                                           FontSize="{Binding LargeFontSize}" HorizontalAlignment="Center"/>
                                <TextBlock Foreground="#fab387" FontWeight="SemiBold"
                                           FontSize="{Binding BaseFontSize}" HorizontalAlignment="Center" Margin="0,2,0,8">
                                    <Run Text="{Binding PodiumEntries[2].Score, Mode=OneWay}"/><Run Text=" pts"/>
                                </TextBlock>
                                <Border Background="#fab387" CornerRadius="4,4,0,0" Width="140"
                                        Height="{Binding PodiumEntries[2].BlockHeight}">
                                    <TextBlock Text="3rd" Foreground="#1e1e2e" FontWeight="Bold" FontSize="36"
                                               HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Podium base shadow -->
                        <Border Background="#45475a" Height="6" Width="500" Margin="0,0,0,28"/>

                        <!-- 4th place: participation ribbon -->
                        <Border Background="#1e1e2e" BorderBrush="#a6adc8" BorderThickness="1"
                                CornerRadius="8" Padding="18,12" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding PodiumEntries[3].Medal}" FontSize="38" VerticalAlignment="Center"/>
                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="4th" Foreground="#a6adc8"
                                               FontSize="{Binding SmallFontSize}"/>
                                    <TextBlock Foreground="#cdd6f4" FontWeight="SemiBold"
                                               FontSize="{Binding LargeFontSize}">
                                        <Run Text="{Binding PodiumEntries[3].Name, Mode=OneWay}"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding PodiumEntries[3].Score, Mode=OneWay}"/>
                                        <Run Text=" pts"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Footer -->
            <TextBlock Grid.Row="2" Foreground="#6c7086" HorizontalAlignment="Center" Margin="0,15,0,0"
                       Visibility="{Binding IsGameComplete, Converter={StaticResource InverseBoolToVis}}"><Run Text="Round "/><Run Text="{Binding CurrentHandNumber, Mode=OneWay}"/><Run Text=" of "/><Run Text="{Binding TotalRounds, Mode=OneWay}"/></TextBlock>
                        </Grid>
                    </Border>
                    </ScrollViewer>
                </TabItem>
                
                <!-- ==================== TAB 2: GAME TRACKERS ==================== -->
                <TabItem Header="Game Trackers">
                    <Border Background="#1e1e2e" Padding="20,15,20,0" HorizontalAlignment="Center"
                            MaxWidth="{Binding GameFlowMaxWidth}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Player Scores -->
                                <TextBlock Text="Player Scores" FontSize="{Binding XXLargeFontSize}" FontWeight="Bold" 
                                           Foreground="#cdd6f4" Margin="0,0,0,15"/>
                                
                                <ItemsControl ItemsSource="{Binding Players}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#313244" CornerRadius="10" Padding="15" Margin="0,0,10,15">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="{Binding DataContext.XXLargeFontSize, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="Bold" Foreground="#cdd6f4"/>
                                                    <TextBlock Text="{Binding PositionName}" Foreground="#a6adc8" FontSize="{Binding DataContext.MediumFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    <TextBlock Text="{Binding TotalScore}" FontSize="{Binding DataContext.TitleFontSize, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="Bold" 
                                                               Foreground="#a6e3a1" Margin="0,10,0,0"/>
                                                    <TextBlock Foreground="#6c7086" FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,5,0,0">
                                                        <Run Text="{Binding RemainingContracts.Count, Mode=OneWay}"/>
                                                        <Run Text=" games remaining"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <!-- Dealer Doubles Matrix -->
                                <TextBlock Text="Dealer Doubles Tracker" FontSize="{Binding XXLargeFontSize}" FontWeight="Bold" 
                                           Foreground="#cdd6f4" Margin="0,20,0,10"/>
                                <TextBlock Text="Track doubles: Each player must double each dealer at least twice during the game." 
                                           Foreground="#a6adc8" FontSize="{Binding MediumFontSize}" Margin="0,0,0,15"/>
                                
                                <Border Background="#313244" CornerRadius="10" Padding="15" HorizontalAlignment="Stretch"
                                        Grid.IsSharedSizeScope="True">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Header Row -->
                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="DTLabel"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Margin="0,0,20,0" FontWeight="SemiBold" FontSize="{Binding BaseFontSize}"><Run Text="Doubler ↓ / " Foreground="#f9e2af"/><Run Text="Dealer →" Foreground="#89b4fa"/></TextBlock>
                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding Players}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" 
                                                                   TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding Name}"
                                                                   Foreground="#89b4fa" FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                        
                                        <!-- Data Rows -->
                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding DealerDoubleMatrix}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="DTLabel"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Doubler.Name}" Margin="0,0,20,0" VerticalAlignment="Center" Foreground="#f9e2af" FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding DoubleCounts}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <UniformGrid Rows="1"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Padding="5" Margin="0,0,0,0">
                                                                        <TextBlock Text="{Binding DisplayText}" TextAlignment="Center"
                                                                                   FontWeight="SemiBold" FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#f38ba8"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding ColorCategory}" Value="1">
                                                                                            <Setter Property="Foreground" Value="#f9e2af"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding ColorCategory}" Value="2">
                                                                                            <Setter Property="Foreground" Value="#a6e3a1"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>
                
                <!-- ==================== TAB 3: SCORE CARD ==================== -->
                <TabItem Header="Score Card">
                    <Border Background="#1e1e2e" Padding="20,15,20,0" HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                                <TextBlock Text="Score Card" FontSize="{Binding XXLargeFontSize}" FontWeight="Bold" 
                                           Foreground="#cdd6f4" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                                    <Border Background="#f9e2af" CornerRadius="8" Width="16" Height="16" Margin="0,0,5,0"/>
                                    <TextBlock Text="Doubled" Foreground="#a6adc8" FontSize="{Binding MediumFontSize}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                    <Border Background="#f38ba8" Width="14" Height="14" Margin="0,0,5,0" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <RotateTransform Angle="45"/>
                                        </Border.RenderTransform>
                                    </Border>
                                    <TextBlock Text="Redoubled" Foreground="#a6adc8" FontSize="{Binding MediumFontSize}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Transposed scorecard: contracts as columns, players as rows -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Scorecard}">
                                    <ItemsControl.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding ScorecardScale}" ScaleY="{Binding ScorecardScale}"/>
                                    </ItemsControl.LayoutTransform>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,18" Grid.IsSharedSizeScope="True">
                                                <!-- Dealer banner -->
                                                <Border Background="#585b70" Padding="10,8" Margin="0,0,0,1" CornerRadius="5,5,0,0">
                                                    <TextBlock FontWeight="Bold" Foreground="#cdd6f4"
                                                               FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Run Text="{Binding Dealer.Name, Mode=OneWay}"/><Run Text="'s Contracts ("/><Run Text="{Binding Dealer.PositionInitial, Mode=OneWay}"/><Run Text=")"/>
                                                    </TextBlock>
                                                </Border>
                                                
                                                <!-- Header row: blank label + one contract name per column -->
                                                <Border Background="#45475a" Padding="8,8" Margin="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ScPlayerCol"/>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ScSepCol"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="" FontWeight="Bold"
                                                                   FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                        <Border Grid.Column="1" Width="1" Background="#6c7086" Margin="5,0"/>
                                                        <ItemsControl Grid.Column="2" ItemsSource="{Binding Rows}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <UniformGrid Rows="1"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Padding="5,0">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="BorderBrush" Value="#6c7086"/>
                                                                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsMostRecent}" Value="True">
                                                                                        <Setter Property="BorderBrush" Value="#f9e2af"/>
                                                                                        <Setter Property="BorderThickness" Value="2"/>
                                                                                        <Setter Property="CornerRadius" Value="4"/>
                                                                                        <Setter Property="Effect">
                                                                                            <Setter.Value>
                                                                                                <DropShadowEffect Color="#f9e2af" BlurRadius="18" ShadowDepth="0" Opacity="0.95"/>
                                                                                            </Setter.Value>
                                                                                        </Setter>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <Grid>
                                                                            <Button Command="{Binding DataContext.StartEditScoreCommand, RelativeSource={RelativeSource AncestorType=ItemsControl, AncestorLevel=3}}"
                                                                                CommandParameter="{Binding}"
                                                                                IsEnabled="{Binding IsPlayed}"
                                                                                HorizontalContentAlignment="Center">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button">
                                                                                    <Setter Property="Cursor" Value="Arrow"/>
                                                                                    <Setter Property="Template">
                                                                                        <Setter.Value>
                                                                                            <ControlTemplate TargetType="Button">
                                                                                                <ContentPresenter HorizontalAlignment="Center"/>
                                                                                            </ControlTemplate>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsPlayed}" Value="True">
                                                                                            <Setter Property="Cursor" Value="Hand"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                            <TextBlock Text="{Binding GameName}" Foreground="#cdd6f4" FontWeight="Bold"
                                                                                       HorizontalAlignment="Center" TextAlignment="Center"
                                                                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding GameName}"
                                                                                       FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsPlayed}" Value="True">
                                                                                                <Setter Property="TextDecorations" Value="Underline"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                            </Button>
                                                                            <ToggleButton x:Name="MostRecentMarker"
                                                                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                                          Margin="0,0,2,0" Padding="0"
                                                                                          Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                                          ToolTip="Most recent completed contract"
                                                                                          Visibility="{Binding IsMostRecent, Converter={StaticResource BoolToVis}}">
                                                                                <ToggleButton.Template>
                                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                    </ControlTemplate>
                                                                                </ToggleButton.Template>
                                                                                <Border Background="#f9e2af" CornerRadius="999"
                                                                                        Width="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                        Height="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                                    <TextBlock Text="i" Foreground="#1e1e2e" FontWeight="Bold" FontStyle="Italic"
                                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                               FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                                </Border>
                                                                            </ToggleButton>
                                                                            <Popup PlacementTarget="{Binding ElementName=MostRecentMarker}" Placement="Bottom"
                                                                                   IsOpen="{Binding IsChecked, ElementName=MostRecentMarker}"
                                                                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                                                                <Border Background="#1e1e2e" BorderBrush="#f9e2af" BorderThickness="1" CornerRadius="6"
                                                                                        Padding="10,8" Margin="0,4,0,0">
                                                                                    <Border.Effect>
                                                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                                                                    </Border.Effect>
                                                                                    <TextBlock Text="Most recent completed contract" Foreground="#cdd6f4"
                                                                                               FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                                </Border>
                                                                            </Popup>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </Border>
                                                
                                                <!-- Player rows: 4 players, each row has cells across all contracts -->
                                                <ItemsControl ItemsSource="{Binding PlayerRows}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#313244" Padding="8,4" Margin="0,0,0,1">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="ScPlayerCol"/>
                                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="ScSepCol"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding PlayerName}" FontWeight="SemiBold"
                                                                               Foreground="#cdd6f4" VerticalAlignment="Center"
                                                                               FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                    <Border Grid.Column="1" Width="1" Background="#6c7086" Margin="5,0"/>
                                                                    <ItemsControl Grid.Column="2" ItemsSource="{Binding Cells}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <UniformGrid Rows="1"/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border BorderBrush="#6c7086" BorderThickness="0,0,1,0" Padding="4,2">
                                                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,3,0">
                                                                                            <ItemsControl ItemsSource="{Binding DoubledTargets}">
                                                                                                <ItemsControl.ItemsPanel>
                                                                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                                                                </ItemsControl.ItemsPanel>
                                                                                                <ItemsControl.ItemTemplate>
                                                                                                    <DataTemplate>
                                                                                                        <Border Background="#f9e2af"
                                                                                                                CornerRadius="{Binding DataContext.CircleCornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                                Width="{Binding DataContext.CircleSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                                Height="{Binding DataContext.CircleSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                                Margin="1,0">
                                                                                                            <TextBlock Text="{Binding}" Foreground="#1e1e2e"
                                                                                                                       FontSize="{Binding DataContext.CircleFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                                       FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                                        </Border>
                                                                                                    </DataTemplate>
                                                                                                </ItemsControl.ItemTemplate>
                                                                                            </ItemsControl>
                                                                                            <ItemsControl ItemsSource="{Binding RedoubledTargets}">
                                                                                                <ItemsControl.ItemsPanel>
                                                                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                                                                </ItemsControl.ItemsPanel>
                                                                                                <ItemsControl.ItemTemplate>
                                                                                                    <DataTemplate>
                                                                                                        <Grid Width="{Binding DataContext.DiamondOuterSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                              Height="{Binding DataContext.DiamondOuterSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                              Margin="1,0">
                                                                                                            <Border Background="#f38ba8"
                                                                                                                    Width="{Binding DataContext.DiamondInnerSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                                    Height="{Binding DataContext.DiamondInnerSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                                    RenderTransformOrigin="0.5,0.5">
                                                                                                                <Border.RenderTransform><RotateTransform Angle="45"/></Border.RenderTransform>
                                                                                                            </Border>
                                                                                                            <TextBlock Text="{Binding}" Foreground="#1e1e2e"
                                                                                                                       FontSize="{Binding DataContext.DiamondFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                                       FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                                        </Grid>
                                                                                                    </DataTemplate>
                                                                                                </ItemsControl.ItemTemplate>
                                                                                            </ItemsControl>
                                                                                        </StackPanel>
                                                                                        <TextBlock Text="{Binding DisplayScore}" TextAlignment="Center" VerticalAlignment="Center"
                                                                                                   FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                                            <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                    <Setter Property="Foreground" Value="#6c7086"/>
                                                                                                    <Style.Triggers>
                                                                                                        <MultiDataTrigger>
                                                                                                            <MultiDataTrigger.Conditions>
                                                                                                                <Condition Binding="{Binding HasScore}" Value="True"/>
                                                                                                                <Condition Binding="{Binding Score, Converter={x:Static local:ScoreSignConverter.Instance}}" Value="True"/>
                                                                                                            </MultiDataTrigger.Conditions>
                                                                                                            <Setter Property="Foreground" Value="#a6e3a1"/>
                                                                                                        </MultiDataTrigger>
                                                                                                        <MultiDataTrigger>
                                                                                                            <MultiDataTrigger.Conditions>
                                                                                                                <Condition Binding="{Binding HasScore}" Value="True"/>
                                                                                                                <Condition Binding="{Binding Score, Converter={x:Static local:ScoreSignConverter.Instance}}" Value="False"/>
                                                                                                            </MultiDataTrigger.Conditions>
                                                                                                            <Setter Property="Foreground" Value="#f38ba8"/>
                                                                                                        </MultiDataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                
                                                <!-- Check sum row: per-contract column totals -->
                                                <Border Background="#3a3d52" Padding="8,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ScPlayerCol"/>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ScSepCol"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="Check" FontWeight="Bold" Foreground="#a6adc8" VerticalAlignment="Center"
                                                                       FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                            <ToggleButton x:Name="CheckInfoToggle" Margin="6,0,0,0" VerticalAlignment="Center"
                                                                          Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                                          ToolTip="What does the check value mean?">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                                <Border Background="#89b4fa" CornerRadius="999"
                                                                        Width="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        Height="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                    <TextBlock Text="i" Foreground="#1e1e2e" FontWeight="Bold" FontStyle="Italic"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                               FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                </Border>
                                                            </ToggleButton>
                                                            <Popup PlacementTarget="{Binding ElementName=CheckInfoToggle}" Placement="Bottom"
                                                                   IsOpen="{Binding IsChecked, ElementName=CheckInfoToggle}"
                                                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                                                <Border Background="#1e1e2e" BorderBrush="#89b4fa" BorderThickness="1" CornerRadius="6"
                                                                        Padding="12" MaxWidth="360" Margin="0,4,0,0">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                                                    </Border.Effect>
                                                                    <TextBlock Foreground="#cdd6f4" TextWrapping="Wrap"
                                                                               FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                               Text="The check value adds up all players' scores for a game and makes sure it adds up to the expected amount. The check value should be the same regardless of player doubling."/>
                                                                </Border>
                                                            </Popup>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" Width="1" Background="#6c7086" Margin="5,0"/>
                                                        <ItemsControl Grid.Column="2" ItemsSource="{Binding Rows}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <UniformGrid Rows="1"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border BorderBrush="#6c7086" BorderThickness="0,0,1,0" Padding="4,2">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <!-- Balanced: sum + green check -->
                                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                                                        Visibility="{Binding IsCheckBalanced, Converter={StaticResource BoolToVis}}">
                                                                                <TextBlock Text="{Binding CheckSumDisplay}" VerticalAlignment="Center"
                                                                                           Foreground="#a6e3a1" FontWeight="SemiBold"
                                                                                           FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                                <TextBlock Text="&#x2714;" Margin="4,2,0,0" VerticalAlignment="Center"
                                                                                           Foreground="#a6e3a1" FontWeight="Bold"
                                                                                           FontFamily="Segoe UI Symbol"
                                                                                           FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                           ToolTip="Scores balance"/>
                                                                            </StackPanel>
                                                                            <!-- Unbalanced: actual sum + red X -->
                                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                                                        Visibility="{Binding IsCheckUnbalanced, Converter={StaticResource BoolToVis}}">
                                                                                <TextBlock Text="{Binding CheckSumDisplay}" VerticalAlignment="Center"
                                                                                           Foreground="#f38ba8" FontWeight="SemiBold"
                                                                                           FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                                <TextBlock Text="&#x2718;" Margin="4,2,0,0" VerticalAlignment="Center"
                                                                                           Foreground="#f38ba8" FontWeight="Bold"
                                                                                           FontFamily="Segoe UI Symbol"
                                                                                           FontSize="{Binding DataContext.BaseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                           ToolTip="Scores do not balance"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
            
            <!-- Restart Bidding Confirmation Popup -->
            <Grid Visibility="{Binding ShowRestartBiddingConfirm, Converter={StaticResource BoolToVis}}">
                <Border Background="#80000000"/>
                <Border Background="#313244" CornerRadius="12" Padding="30" 
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        MinWidth="350"
                        BorderBrush="#45475a" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Restart Bidding?" FontSize="{Binding XXLargeFontSize}" FontWeight="Bold" 
                                   Foreground="#f9e2af" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Are you sure you want to start the bidding over? All doubles for this round will be reset." 
                                   Foreground="#cdd6f4" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Yes, Restart" Command="{Binding ConfirmRestartBiddingCommand}"
                                    Background="#f38ba8" Foreground="#1e1e2e" FontWeight="Bold"
                                    Padding="20,10" Margin="0,0,15,0"/>
                            <Button Content="Cancel" Command="{Binding CancelRestartBiddingCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        
        <!-- Settings Panel Overlay (global overlay) -->
        <Grid Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="980" Height="700"
                    BorderBrush="#45475a" BorderThickness="1">
                <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Settings Sidebar -->
                        <Border Grid.Column="0" Background="#45475a" CornerRadius="12,0,0,12" MinWidth="200">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Settings Header -->
                                <TextBlock Grid.Row="0" Text="Settings" FontSize="{Binding XLargeFontSize}" FontWeight="Bold" 
                                           Foreground="#cdd6f4" Margin="20,20,20,15"/>
                                
                                <!-- Settings Tab Buttons -->
                                <StackPanel Grid.Row="1">
                                    <Button Content="Game Variants" 
                                            Command="{Binding SelectSettingsTabCommand}" CommandParameter="1"
                                            Background="{Binding SelectedSettingsTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=1}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                    <Button Content="Optional Rules" 
                                            Command="{Binding SelectSettingsTabCommand}" CommandParameter="2"
                                            Background="{Binding SelectedSettingsTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=2}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                    <Button Content="Text Size" 
                                            Command="{Binding SelectSettingsTabCommand}" CommandParameter="0"
                                            Background="{Binding SelectedSettingsTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=0}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Settings Content Area -->
                        <Grid Grid.Column="1" Margin="25">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Tab Content -->
                            <Grid Grid.Row="0">
                                <!-- Tab 0: Text Size -->
                                <StackPanel Visibility="{Binding SelectedSettingsTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=0}">
                                    <TextBlock Text="Text Size" FontSize="{Binding XLargeFontSize}" FontWeight="Bold" 
                                               Foreground="#cdd6f4" Margin="0,0,0,15"/>
                                    <TextBlock Text="Choose a text size for the application." Foreground="#a6adc8" Margin="0,0,0,20"/>
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <RadioButton GroupName="TextSize" Content="Small"
                                                     IsChecked="{Binding SelectedTextSize, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Small}"
                                                     Foreground="#cdd6f4" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <RadioButton GroupName="TextSize" Content="Medium"
                                                     IsChecked="{Binding SelectedTextSize, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Medium}"
                                                     Foreground="#cdd6f4" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <RadioButton GroupName="TextSize" Content="Large"
                                                     IsChecked="{Binding SelectedTextSize, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Large}"
                                                     Foreground="#cdd6f4" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- Tab 1: Game Variants -->
                                <ScrollViewer Visibility="{Binding SelectedSettingsTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=1}"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="Game Variants" FontSize="{Binding XLargeFontSize}" FontWeight="Bold" 
                                                   Foreground="#cdd6f4" Margin="0,0,0,12"/>
                                        
                                        <TextBlock Text="Game Mode" FontSize="{Binding LargeFontSize}" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                                            <RadioButton Content="Standard" Foreground="#cdd6f4" FontSize="{Binding BaseFontSize}"
                                                         VerticalContentAlignment="Center"
                                                         IsChecked="{Binding IsStandardMode, Mode=TwoWay}" GroupName="GameMode"/>
                                            <ToggleButton x:Name="StandardInfoToggle" Margin="6,0,20,0" VerticalAlignment="Center"
                                                          Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                          ToolTip="About Standard">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                                <Border Background="#89b4fa" CornerRadius="999"
                                                        Width="{Binding BaseFontSize}" Height="{Binding BaseFontSize}">
                                                    <TextBlock Text="i" Foreground="#1e1e2e" FontWeight="Bold" FontStyle="Italic"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="{Binding SmallFontSize}"/>
                                                </Border>
                                            </ToggleButton>
                                            <Popup PlacementTarget="{Binding ElementName=StandardInfoToggle}" Placement="Bottom"
                                                   IsOpen="{Binding IsChecked, ElementName=StandardInfoToggle}"
                                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                                <Border Background="#1e1e2e" BorderBrush="#89b4fa" BorderThickness="1" CornerRadius="6"
                                                        Padding="12" MaxWidth="360" Margin="0,4,0,0">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                                    </Border.Effect>
                                                    <TextBlock Foreground="#cdd6f4" TextWrapping="Wrap"
                                                               FontSize="{Binding SmallFontSize}"
                                                               Text="Barbu's original 7 contracts."/>
                                                </Border>
                                            </Popup>
                                            <RadioButton Content="Salade" Foreground="#cdd6f4" FontSize="{Binding BaseFontSize}"
                                                         VerticalContentAlignment="Center"
                                                         IsChecked="{Binding IsSaladeMode, Mode=TwoWay}" GroupName="GameMode"/>
                                            <ToggleButton x:Name="SaladeInfoToggle" Margin="6,0,0,0" VerticalAlignment="Center"
                                                          Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                          ToolTip="About Salade">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                                <Border Background="#89b4fa" CornerRadius="999"
                                                        Width="{Binding BaseFontSize}" Height="{Binding BaseFontSize}">
                                                    <TextBlock Text="i" Foreground="#1e1e2e" FontWeight="Bold" FontStyle="Italic"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="{Binding SmallFontSize}"/>
                                                </Border>
                                            </ToggleButton>
                                            <Popup PlacementTarget="{Binding ElementName=SaladeInfoToggle}" Placement="Bottom"
                                                   IsOpen="{Binding IsChecked, ElementName=SaladeInfoToggle}"
                                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                                <Border Background="#1e1e2e" BorderBrush="#89b4fa" BorderThickness="1" CornerRadius="6"
                                                        Padding="12" MaxWidth="360" Margin="0,4,0,0">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                                    </Border.Effect>
                                                    <TextBlock Foreground="#cdd6f4" TextWrapping="Wrap"
                                                               FontSize="{Binding SmallFontSize}">
                                                        <Run Text="Replaces the Trumps and "/><Run Text="{Binding FanTanContractName, Mode=OneWay}"/><Run Text=" contracts with an alternative 6th contract. Remaining 5 original contracts are also modified slightly."/>
                                                    </TextBlock>
                                                </Border>
                                            </Popup>
                                        </StackPanel>
                                        
                                        <TextBlock Text="Contract Names" FontSize="{Binding LargeFontSize}" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                                            <RadioButton Content="Classic" Foreground="#cdd6f4" FontSize="{Binding BaseFontSize}"
                                                         VerticalContentAlignment="Center"
                                                         IsChecked="{Binding IsClassicNames, Mode=TwoWay}" GroupName="ContractNames"/>
                                            <ToggleButton x:Name="ClassicInfoToggle" Margin="6,0,20,0" VerticalAlignment="Center"
                                                          Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                          ToolTip="About Classic names">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                                <Border Background="#89b4fa" CornerRadius="999"
                                                        Width="{Binding BaseFontSize}" Height="{Binding BaseFontSize}">
                                                    <TextBlock Text="i" Foreground="#1e1e2e" FontWeight="Bold" FontStyle="Italic"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="{Binding SmallFontSize}"/>
                                                </Border>
                                            </ToggleButton>
                                            <Popup PlacementTarget="{Binding ElementName=ClassicInfoToggle}" Placement="Bottom"
                                                   IsOpen="{Binding IsChecked, ElementName=ClassicInfoToggle}"
                                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                                <Border Background="#1e1e2e" BorderBrush="#89b4fa" BorderThickness="1" CornerRadius="6"
                                                        Padding="12" MaxWidth="420" Margin="0,4,0,0">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                                    </Border.Effect>
                                                    <TextBlock Foreground="#cdd6f4" TextWrapping="Wrap"
                                                               FontSize="{Binding SmallFontSize}"
                                                               Text="Classic: Nullo, No Queens, Hearts, No Last Two, Barbu, Trumps, Fan Tan"/>
                                                </Border>
                                            </Popup>
                                            <RadioButton Content="Modern" Foreground="#cdd6f4" FontSize="{Binding BaseFontSize}"
                                                         VerticalContentAlignment="Center"
                                                         IsChecked="{Binding IsModernNames, Mode=TwoWay}" GroupName="ContractNames"/>
                                            <ToggleButton x:Name="ModernInfoToggle" Margin="6,0,0,0" VerticalAlignment="Center"
                                                          Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                          ToolTip="About Modern names">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                                <Border Background="#89b4fa" CornerRadius="999"
                                                        Width="{Binding BaseFontSize}" Height="{Binding BaseFontSize}">
                                                    <TextBlock Text="i" Foreground="#1e1e2e" FontWeight="Bold" FontStyle="Italic"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="{Binding SmallFontSize}"/>
                                                </Border>
                                            </ToggleButton>
                                            <Popup PlacementTarget="{Binding ElementName=ModernInfoToggle}" Placement="Bottom"
                                                   IsOpen="{Binding IsChecked, ElementName=ModernInfoToggle}"
                                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                                <Border Background="#1e1e2e" BorderBrush="#89b4fa" BorderThickness="1" CornerRadius="6"
                                                        Padding="12" MaxWidth="460" Margin="0,4,0,0">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                                    </Border.Effect>
                                                    <TextBlock Foreground="#cdd6f4" TextWrapping="Wrap"
                                                               FontSize="{Binding SmallFontSize}"
                                                               Text="Modern: No Tricks, No Queens, No Hearts, No Last Two, No King of Hearts, Trumps, Domino"/>
                                                </Border>
                                            </Popup>
                                        </StackPanel>
                                        
                                        <TextBlock Text="{Binding FanTanScoringHeader}" FontSize="{Binding LargeFontSize}" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                                            <TextBlock Text="{Binding FanTanScoringDisplay}" Foreground="#cdd6f4" FontSize="{Binding BaseFontSize}" 
                                                       VerticalAlignment="Center" Margin="0,0,15,0"/>
                                            <Button Content="Edit" Command="{Binding OpenFanTanScoringEditorCommand}"
                                                    Style="{StaticResource SettingsEditButtonStyle}"/>
                                        </StackPanel>
                                        
                                        <TextBlock Text="Optional Contracts" FontSize="{Binding LargeFontSize}" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <CheckBox Content="Ravage City (8th contract)" Foreground="#cdd6f4" FontSize="{Binding BaseFontSize}"
                                                      VerticalContentAlignment="Center"
                                                      IsChecked="{Binding RavageCityEnabled, Mode=TwoWay}"
                                                      IsEnabled="{Binding NotSaladeMode}">
                                                <CheckBox.Style>
                                                    <Style TargetType="CheckBox">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Opacity" Value="0.45"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </CheckBox.Style>
                                            </CheckBox>
                                            <ToggleButton x:Name="RavageCityInfoToggle" Margin="6,0,0,0" VerticalAlignment="Center"
                                                          Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                          ToolTip="About Ravage City">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                                <Border Background="#89b4fa" CornerRadius="999"
                                                        Width="{Binding BaseFontSize}" Height="{Binding BaseFontSize}">
                                                    <TextBlock Text="i" Foreground="#1e1e2e" FontWeight="Bold" FontStyle="Italic"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="{Binding SmallFontSize}"/>
                                                </Border>
                                            </ToggleButton>
                                            <Popup PlacementTarget="{Binding ElementName=RavageCityInfoToggle}" Placement="Bottom"
                                                   IsOpen="{Binding IsChecked, ElementName=RavageCityInfoToggle}"
                                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                                <Border Background="#1e1e2e" BorderBrush="#89b4fa" BorderThickness="1" CornerRadius="6"
                                                        Padding="12" MaxWidth="420" Margin="0,4,0,0">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                                    </Border.Effect>
                                                    <TextBlock Foreground="#cdd6f4" TextWrapping="Wrap"
                                                               FontSize="{Binding SmallFontSize}"
                                                               Text="The player who takes the most cards in any one suit scores &#x2212;24. If two tie, each scores &#x2212;12. If three tie, each scores &#x2212;8, and all get &#x2212;6 for a four-way tie. Scoring for original 7 contracts is adjusted to maintain zero sum game."/>
                                                </Border>
                                            </Popup>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <CheckBox Content="Chinese Poker (9th contract)" Foreground="#cdd6f4" FontSize="{Binding BaseFontSize}"
                                                      VerticalContentAlignment="Center"
                                                      IsChecked="{Binding ChinesePokerEnabled, Mode=TwoWay}"
                                                      IsEnabled="{Binding NotSaladeMode}">
                                                <CheckBox.Style>
                                                    <Style TargetType="CheckBox">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Opacity" Value="0.45"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </CheckBox.Style>
                                            </CheckBox>
                                            <ToggleButton x:Name="ChinesePokerInfoToggle" Margin="6,0,0,0" VerticalAlignment="Center"
                                                          Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                          ToolTip="About Chinese Poker">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                                <Border Background="#89b4fa" CornerRadius="999"
                                                        Width="{Binding BaseFontSize}" Height="{Binding BaseFontSize}">
                                                    <TextBlock Text="i" Foreground="#1e1e2e" FontWeight="Bold" FontStyle="Italic"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="{Binding SmallFontSize}"/>
                                                </Border>
                                            </ToggleButton>
                                            <Popup PlacementTarget="{Binding ElementName=ChinesePokerInfoToggle}" Placement="Bottom"
                                                   IsOpen="{Binding IsChecked, ElementName=ChinesePokerInfoToggle}"
                                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                                <Border Background="#1e1e2e" BorderBrush="#89b4fa" BorderThickness="1" CornerRadius="6"
                                                        Padding="12" MaxWidth="320" Margin="0,4,0,0">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                                    </Border.Effect>
                                                    <TextBlock Foreground="#cdd6f4" TextWrapping="Wrap"
                                                               FontSize="{Binding SmallFontSize}"
                                                               Text="Organize your hand into 3 settings (Front/Middle/Back) making poker hands. For each setting you gain +4 points per player your hand beats (+72 points total). Scoring of other games is adjusted to maintain zero sum game."/>
                                                </Border>
                                            </Popup>
                                        </StackPanel>
                                        <TextBlock Foreground="#6c7086" FontSize="{Binding MediumFontSize}" Margin="0,0,0,0" TextWrapping="Wrap"
                                                   Visibility="{Binding IsSaladeMode, Converter={StaticResource BoolToVis}}">
                                            <Run Text="Optional contracts are not available in Salade mode."/>
                                        </TextBlock>
                                    </StackPanel>
                                </ScrollViewer>
                                
                                <!-- Tab 2: Optional Rules -->
                                <StackPanel Visibility="{Binding SelectedSettingsTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=2}">
                                    <TextBlock Text="Optional Rules" FontSize="{Binding XLargeFontSize}" FontWeight="Bold" 
                                               Foreground="#cdd6f4" Margin="0,0,0,15"/>
                                    
                                    <TextBlock Text="Doubling Rules" FontSize="{Binding LargeFontSize}" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,8"/>
                                    <StackPanel>
                                        <CheckBox Content="Dealer allowed to double" Foreground="#cdd6f4" FontSize="{Binding BaseFontSize}"
                                                  IsChecked="{Binding DealerAllowedToDouble, Mode=TwoWay}"/>
                                        <TextBlock Text="When unchecked, the dealer cannot double other players but may only redouble." 
                                                   Foreground="#6c7086" FontSize="{Binding MediumFontSize}" Margin="25,5,0,0" TextWrapping="Wrap"/>
                                        <CheckBox Content="Double non-dealers for positive contracts" Foreground="#cdd6f4" FontSize="{Binding BaseFontSize}"
                                                  IsChecked="{Binding AllowNonDealerDoublesInPositive, Mode=TwoWay}" Margin="0,12,0,0"/>
                                        <TextBlock Text="When unchecked, during positive contracts (Trumps, Fan Tan, Chinese Poker) non-dealers can only double the dealer."
                                                   Foreground="#6c7086" FontSize="{Binding MediumFontSize}" Margin="25,5,0,0" TextWrapping="Wrap"/>
                                        <CheckBox Content="Skip negative contracts when no doubles" Foreground="#cdd6f4" FontSize="{Binding BaseFontSize}"
                                                  IsChecked="{Binding SkipNegativeContractOnNoDoubles, Mode=TwoWay}" Margin="0,12,0,0"/>
                                        <TextBlock Text="When checked (default), confirming bidding with no doubles on a negative contract (Nullo, Hearts, No Queens, No Last Two, Barbu, Ravage City, Salade) skips score entry and splits the contract's check total among the non-dealers (the dealer absorbs the remainder)."
                                                   Foreground="#6c7086" FontSize="{Binding MediumFontSize}" Margin="25,5,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Close Buttons -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Close" Command="{Binding DiscardSettingsCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="20,10" Margin="0,0,10,0"/>
                                <Button Content="Save and Close" Command="{Binding CloseSettingsCommand}"
                                        Background="#89b4fa" Foreground="#1e1e2e" FontWeight="Bold"
                                        Padding="20,10"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        
        <!-- How To Play Panel Overlay -->
        <Grid Visibility="{Binding IsHowToPlayOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="980" Height="700"
                    BorderBrush="#45475a" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- How To Play Sidebar -->
                    <Border Grid.Column="0" Background="#45475a" CornerRadius="12,0,0,12" MinWidth="220">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="How To Play" FontSize="{Binding XLargeFontSize}" FontWeight="Bold"
                                       Foreground="#cdd6f4" Margin="20,20,20,15"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Button Content="General Rules" Command="{Binding SelectHowToPlayTabCommand}" CommandParameter="0"
                                            Background="{Binding SelectedHowToPlayTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=0}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                    <Button Content="{Binding HowToPlayName_Nullo}" Command="{Binding SelectHowToPlayTabCommand}" CommandParameter="1"
                                            Background="{Binding SelectedHowToPlayTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=1}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                    <Button Content="{Binding HowToPlayName_NoQueens}" Command="{Binding SelectHowToPlayTabCommand}" CommandParameter="2"
                                            Background="{Binding SelectedHowToPlayTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=2}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                    <Button Content="{Binding HowToPlayName_Hearts}" Command="{Binding SelectHowToPlayTabCommand}" CommandParameter="3"
                                            Background="{Binding SelectedHowToPlayTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=3}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                    <Button Content="{Binding HowToPlayName_NoLastTwo}" Command="{Binding SelectHowToPlayTabCommand}" CommandParameter="4"
                                            Background="{Binding SelectedHowToPlayTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=4}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                    <Button Content="{Binding HowToPlayName_Barbu}" Command="{Binding SelectHowToPlayTabCommand}" CommandParameter="5"
                                            Background="{Binding SelectedHowToPlayTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=5}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                    <Button Content="{Binding HowToPlayName_Trumps}" Command="{Binding SelectHowToPlayTabCommand}" CommandParameter="6"
                                            Background="{Binding SelectedHowToPlayTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=6}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                    <Button Content="{Binding HowToPlayName_FanTan}" Command="{Binding SelectHowToPlayTabCommand}" CommandParameter="7"
                                            Background="{Binding SelectedHowToPlayTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=7}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                    <Button Content="{Binding HowToPlayName_RavageCity}" Command="{Binding SelectHowToPlayTabCommand}" CommandParameter="8"
                                            Background="{Binding SelectedHowToPlayTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=8}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                    <Button Content="{Binding HowToPlayName_ChinesePoker}" Command="{Binding SelectHowToPlayTabCommand}" CommandParameter="9"
                                            Background="{Binding SelectedHowToPlayTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=9}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                    <Button Content="{Binding HowToPlayName_Salade}" Command="{Binding SelectHowToPlayTabCommand}" CommandParameter="10"
                                            Background="{Binding SelectedHowToPlayTab, Converter={StaticResource TabSelectedConverter}, ConverterParameter=10}"
                                            Style="{StaticResource SettingsTabButtonStyle}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- How To Play Content Area -->
                    <Grid Grid.Column="1" Margin="25">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" TextElement.FontSize="{Binding TinyFontSize}">
                            <ScrollViewer Visibility="{Binding SelectedHowToPlayTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=0}" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="General Rules" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,12"/>

                                    <TextBlock Text="Overview" FontSize="{Binding MediumFontSize}" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,4"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="0,0,0,10"
                                               Text="Barbu (French for &#x2018;The Bearded One&#x2019; referring to the King of Hearts) is a 4&#x2011;player trick&#x2011;taking game played with a standard 52&#x2011;card deck (Ace is high). The game consists of 7 contracts (unique games) for a total of 28 deals. Each player, when its their turn to be the dealer, deals 13 cards to each player, looks at their hand, and declares which contract the group will play. Players then complete the &quot;Doubling&quot; bid. Finally, the game is played and then scored including adding and removing points based on doubling."/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="0,0,0,18"
                                               Text="There are 7 contracts within Barbu. Five of these contracts are 'negative' games where the object is to avoid taking tricks or tricks containing penalty cards. The remaining two contracts are 'positive' games where you want to score as many points as possible."/>

                                    <TextBlock Text="Doubling" FontSize="{Binding MediumFontSize}" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,4"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="0,0,0,10"
                                               Text="Players may choose to &quot;double&quot; after the contract is selected, placing a side bet against one or more opponents. A double compares the two players' scores for that hand, awarding the higher scorer the difference and subtracting the same amount from the lower scorer. Anyone who is doubled may redouble, which raises the stakes by doubling the difference between the players' scores before awarding the higher scorer the difference and subtracting the same amount from the lower scorer. Calling &#x201C;Max&#x201D; means doubling every opponent you are allowed to double and redoubling all players who doubled you."/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="In positive contracts, players may only double the dealer."/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="The dealer may redouble anyone who doubles them, but cannot initiate a double."/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="Each player must double the dealer at least twice across that dealer&#x2019;s seven contracts."/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,18">
                                        <Run Text="&#x2022;  "/><Run Text="If no doubles are made in a negative contract, the hand is skipped and the penalty points are divided among the three non&#x2011;dealers, with the dealer scoring nothing (or +1 if needed for balance)."/>
                                    </TextBlock>

                                    <TextBlock Text="Play" FontSize="{Binding MediumFontSize}" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,4"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="0,0,0,18"
                                               Text="The dealer always leads the first trick and the winner of each trick leads the following trick. Players must follow suit if able, and each trick is won by the highest card of the suit led. There is no trump suit except in the contract Trumps."/>

                                    <TextBlock Text="Scoring" FontSize="{Binding MediumFontSize}" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,4"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="0,0,0,10"
                                               Text="Once a round is complete, start by writing each player's base score. Then compare the score of each pair of players who had a double or redouble between them. If there was only a double, take the difference between their scores and add the difference to the higher scoring player, then subtract the same amount from the lower scoring player. If it's a redouble, double the difference before adding/subtracting. Once all the final scores are calculated, add all players' scores together and compare it with the contract's check value. If the two values do not match, then a mistake was made during scoring."/>
                                </StackPanel>
                            </ScrollViewer>
                            <ScrollViewer Visibility="{Binding SelectedHowToPlayTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=1}" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding HowToPlayName_Nullo}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,12"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4"
                                               Text="The objective is to take as few tricks as possible. Each trick scores -2 points. The total score for checks is -26."/>
                                </StackPanel>
                            </ScrollViewer>
                            <ScrollViewer Visibility="{Binding SelectedHowToPlayTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=2}" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding HowToPlayName_NoQueens}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,12"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4"
                                               Text="The objective is to avoid taking tricks containing a Queen of any suit. For each Queen taken the player scores -6 points. Once all 4 Queens have been won, the round ends. The total score for checks is -24."/>
                                </StackPanel>
                            </ScrollViewer>
                            <ScrollViewer Visibility="{Binding SelectedHowToPlayTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=3}" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding HowToPlayName_Hearts}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,12"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4"
                                               Text="The objective is to avoid taking tricks containing any hearts. Each heart taken scores -2 points (except for the Ace which is -6 points). In this contract there is a special rule: Hearts may not be led unless the player has no cards of any other suit remaining. Once all hearts have been played, the round ends. The total score for checks is -30."/>
                                </StackPanel>
                            </ScrollViewer>
                            <ScrollViewer Visibility="{Binding SelectedHowToPlayTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=4}" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding HowToPlayName_NoLastTwo}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,12"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4"
                                               Text="The objective is to avoid taking the last two tricks. The last trick scores -20 points, the penultimate (2nd to last) trick scores -10 points. The total score for checks is -30."/>
                                </StackPanel>
                            </ScrollViewer>
                            <ScrollViewer Visibility="{Binding SelectedHowToPlayTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=5}" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding HowToPlayName_Barbu}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,12"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4"
                                               Text="The objective is to avoid taking the trick containing the King of Hearts. Whoever does scores -20 points. In this contract there is a special rule: Hearts may not be led unless the player has no cards of any other suit remaining. Once a player wins a trick containing the King of Hearts, the round ends. The total score for checks is -20."/>
                                </StackPanel>
                            </ScrollViewer>
                            <ScrollViewer Visibility="{Binding SelectedHowToPlayTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=6}" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding HowToPlayName_Trumps}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,12"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4"
                                               Text="The objective is to win as many tricks as possible. Each trick is worth +5 points. The dealer declares the trump suit. If you cannot follow suit, you must play a trump if able, and if a trump has already been played, you must over&#x2011;trump if able. You are not required to under&#x2011;trump. When a trump is led, you must play a higher trump if able. Each trick is worth 5 points. The total score for checks is +65."/>
                                </StackPanel>
                            </ScrollViewer>
                            <ScrollViewer Visibility="{Binding SelectedHowToPlayTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=7}" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding HowToPlayName_FanTan}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,12"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4"
                                               Text="The objective is to play all your cards as quickly as possible. The dealer names a starting rank (example: starting with 7's), and on each turn a player must play either a card of that rank or a card one rank higher or lower than any card already played in that suit. If a player cannot play, their turn is skipped. Scoring is based on the order in which players empty their hands: 1st = +40, 2nd = +25, 3rd = +10, 4th = &#x2013;10. However, these values can vary (Example: 45/20/5/-5) and can be edited under Game Settings. The total score for checks is +65."/>
                                </StackPanel>
                            </ScrollViewer>
                            <ScrollViewer Visibility="{Binding SelectedHowToPlayTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=8}" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding HowToPlayName_RavageCity}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,12"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="0,0,0,10"
                                               Text="Ravage City is an optional 8th contract. The objective to not win the most cards in any suit. The player who takes the most cards in any one suit scores -24 points. If two players tie, each scores -12 points. If three players tie, each scores -8 points. If all players tie, each scores -6 points. To maintain zero-sum scoring, the values of the other contracts are modified as follows:"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="{Binding HowToPlayName_Nullo, Mode=OneWay}"/><Run Text=": Each trick scores -3 (-39 total)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="{Binding HowToPlayName_Hearts, Mode=OneWay}"/><Run Text=": No change; -2 per heart, -6 for Ace of Hearts (-30 total)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="{Binding HowToPlayName_NoQueens, Mode=OneWay}"/><Run Text=": Each queen scores -8 (-32 total)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="{Binding HowToPlayName_Barbu, Mode=OneWay}"/><Run Text=": King of Hearts scores -21"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="No Last Two: No change &#x2013; 2nd to last trick scores -10, last trick scores -20 (-30 total)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="{Binding HowToPlayName_Trumps, Mode=OneWay}"/><Run Text=": Each trick scores +7 (+91 total)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="{Binding HowToPlayName_FanTan, Mode=OneWay}"/><Run Text=": First player out scores +50, second +25, third +10, and fourth scores 0 (+85 total)"/>
                                    </TextBlock>
                                </StackPanel>
                            </ScrollViewer>
                            <ScrollViewer Visibility="{Binding SelectedHowToPlayTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=9}" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding HowToPlayName_ChinesePoker}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,12"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="0,0,0,10"
                                               Text="Chinese Poker is an optional 9th contract that can be added in addition to Ravage City. The objective is to win the most &quot;beats&quot; which is when your hand beats another player's hand according to standard poker hands. Each beat scores +4 points. Check value is +72 points."/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="0,0,0,10"
                                               Text="Each player organizes their hands into 3 groups or settings: Front, Middle, and Back. The Front setting is composed of 3 cards while the Middle and Back have 5 cards each. Each setting must be a better poker hand than the previous (Front &lt; Middle &lt; Back)."/>
                                    <TextBlock Text="Poker Hands (in order from highest to lowest)" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  " /><Run Text="Royal Flush" FontWeight="SemiBold"/><Run Text=" - An ace high straight flush"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  " /><Run Text="Straight Flush" FontWeight="SemiBold"/><Run Text=" - Five consecutive cards in the same suit"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  " /><Run Text="Four of a Kind" FontWeight="SemiBold"/><Run Text=" - Four cards of the same rank"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  " /><Run Text="Full House" FontWeight="SemiBold"/><Run Text=" - Three cards of the same rank with 2 cards of another same rank"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  " /><Run Text="Flush" FontWeight="SemiBold"/><Run Text=" - Five cards in the same suit (not consecutive)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  " /><Run Text="Straight" FontWeight="SemiBold"/><Run Text=" - Five consecutive cards of different suits (Aces can count as a high or a low card)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  " /><Run Text="Three of a Kind" FontWeight="SemiBold"/><Run Text=" - Three cards of the same rank"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  " /><Run Text="Two Pair" FontWeight="SemiBold"/><Run Text=" - Two cards of the same rank together with two cards of another same rank"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  " /><Run Text="One Pair" FontWeight="SemiBold"/><Run Text=" - Two cards of the same rank"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,10">
                                        <Run Text="&#x2022;  " /><Run Text="High Card" FontWeight="SemiBold"/><Run Text=" - Five cards of different rank and suit (that do not form any of the above hands). Hands are ranked by comparing the highest value card."/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4"
                                               Text="For each setting, compare your hand with each other player. Gain 1 beat for each time your hand beats the hand of another player. 6 beats are available per setting among the players."/>
                                </StackPanel>
                            </ScrollViewer>
                            <ScrollViewer Visibility="{Binding SelectedHowToPlayTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=10}" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding HowToPlayName_Salade}" FontSize="{Binding LargeFontSize}" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,0,12"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="0,0,0,10"
                                               Text="Salade is an additional round played in a variant based on the negative contracts. In this game there are no positive contracts and the five negative contracts are varied slightly as follows, and Salade is a sixth round."/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="{Binding HowToPlayName_Nullo, Mode=OneWay}"/><Run Text=": Each trick scores -5 (total -65)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="No Last Trick: -30 total (note, only the last trick)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="{Binding HowToPlayName_Hearts, Mode=OneWay}"/><Run Text=": Each hearts score -10 (-130 total)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="{Binding HowToPlayName_NoQueens, Mode=OneWay}"/><Run Text=": Each queen scores -20 (-80 total)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,4">
                                        <Run Text="&#x2022;  "/><Run Text="{Binding HowToPlayName_Barbu, Mode=OneWay}"/><Run Text=": King of Hearts scores -50"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4" Margin="16,0,0,10">
                                        <Run Text="&#x2022;  "/><Run Text="{Binding HowToPlayName_Salade, Mode=OneWay}"/><Run Text=": All of the above, simultaneously (-355 total)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Foreground="#cdd6f4"
                                               Text="Barbu with the Salade variant is composed of 24 rounds, with strategy for Salade being critical. This variant is strictly for fun &#x2013; for example, players will gang up on the leader going into the salade, forgetting their own position."/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Close" Command="{Binding CloseHowToPlayCommand}"
                                    Background="#89b4fa" Foreground="#1e1e2e" FontWeight="Bold"
                                    Padding="20,10"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Fan Tan Scoring Editor Popup -->
        <Grid Visibility="{Binding ShowFanTanScoringEditor, Converter={StaticResource BoolToVis}}">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="25" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="500"
                    BorderBrush="#45475a" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Edit Fan Tan/Domino Scoring" FontSize="{Binding XLargeFontSize}" FontWeight="Bold" 
                               Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="{Binding FanTanScoringRequiredTotalDisplay}" Foreground="#a6adc8" 
                               HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Column="0" Grid.Row="0" Text="1st" Foreground="#cdd6f4" 
                                   HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Grid.Column="1" Grid.Row="0" Text="2nd" Foreground="#cdd6f4" 
                                   HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Grid.Column="2" Grid.Row="0" Text="3rd" Foreground="#cdd6f4" 
                                   HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Grid.Column="3" Grid.Row="0" Text="4th" Foreground="#cdd6f4" 
                                   HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        
                        <TextBox Grid.Column="0" Grid.Row="1" Text="{Binding TempFanTanScore1st, UpdateSourceTrigger=PropertyChanged}" 
                                 MinWidth="80" HorizontalAlignment="Center" TextAlignment="Center" Padding="6,4"
                                 Background="#45475a" Foreground="#cdd6f4" BorderThickness="1" BorderBrush="#585b70" Margin="5"/>
                        <TextBox Grid.Column="1" Grid.Row="1" Text="{Binding TempFanTanScore2nd, UpdateSourceTrigger=PropertyChanged}" 
                                 MinWidth="80" HorizontalAlignment="Center" TextAlignment="Center" Padding="6,4"
                                 Background="#45475a" Foreground="#cdd6f4" BorderThickness="1" BorderBrush="#585b70" Margin="5"/>
                        <TextBox Grid.Column="2" Grid.Row="1" Text="{Binding TempFanTanScore3rd, UpdateSourceTrigger=PropertyChanged}" 
                                 MinWidth="80" HorizontalAlignment="Center" TextAlignment="Center" Padding="6,4"
                                 Background="#45475a" Foreground="#cdd6f4" BorderThickness="1" BorderBrush="#585b70" Margin="5"/>
                        <TextBox Grid.Column="3" Grid.Row="1" Text="{Binding TempFanTanScore4th, UpdateSourceTrigger=PropertyChanged}" 
                                 MinWidth="80" HorizontalAlignment="Center" TextAlignment="Center" Padding="6,4"
                                 Background="#45475a" Foreground="#cdd6f4" BorderThickness="1" BorderBrush="#585b70" Margin="5"/>
                    </Grid>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="Current total: " Foreground="#a6adc8"/>
                        <TextBlock Text="{Binding TempFanTanScoringTotal}" 
                                   Foreground="{Binding IsTempFanTanScoringValid, Converter={StaticResource BoolToColorConverter}}"/>
                        <TextBlock Foreground="#a6adc8">
                            <Run Text=" (must equal "/><Run Text="{Binding FanTanScoringRequiredTotal, Mode=OneWay}"/><Run Text=")"/>
                        </TextBlock>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Save" Command="{Binding SaveFanTanScoringCommand}"
                                Background="#89b4fa" Foreground="#1e1e2e" FontWeight="Bold"
                                Padding="20,8" Margin="0,0,10,0" BorderThickness="0"
                                IsEnabled="{Binding IsTempFanTanScoringValid}"/>
                        <Button Content="Discard" Command="{Binding DiscardFanTanScoringCommand}"
                                Background="#585b70" Foreground="#cdd6f4"
                                Padding="20,8" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Save As Prompt (global overlay) -->
        <Grid Visibility="{Binding ShowSaveAsPrompt, Converter={StaticResource BoolToVis}}">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="30"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="420" BorderBrush="#45475a" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Save As" FontSize="{Binding XXLargeFontSize}" FontWeight="Bold"
                               Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Save the current game to a new file. Future auto-saves will go to this new file."
                               Foreground="#a6adc8" TextWrapping="Wrap" Margin="0,0,0,15"/>
                    <TextBlock Text="Name" Foreground="#cdd6f4" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding SaveAsName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="{Binding BaseFontSize}"
                             Padding="8,6" Background="#1e1e2e" Foreground="#cdd6f4"
                             BorderBrush="#585b70" BorderThickness="1">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding ConfirmSaveAsCommand}"/>
                            <KeyBinding Key="Escape" Command="{Binding CancelSaveAsCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <TextBlock Text="{Binding SaveAsErrorMessage}" Foreground="#f38ba8"
                               Visibility="{Binding HasSaveAsError, Converter={StaticResource BoolToVis}}"
                               TextWrapping="Wrap" Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Content="Cancel" Command="{Binding CancelSaveAsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Save" Command="{Binding ConfirmSaveAsCommand}"
                                Background="#a6e3a1"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Overwrite Save As Confirmation (global overlay) -->
        <Grid Visibility="{Binding ShowOverwriteSaveAsPrompt, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="110">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="30"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="420" BorderBrush="#45475a" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Overwrite saved game?" FontSize="{Binding XXLargeFontSize}" FontWeight="Bold"
                               Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Foreground="#a6adc8" TextWrapping="Wrap" Margin="0,0,0,15">
                        <Run Text="A saved game named &quot;"/><Run Text="{Binding OverwriteSaveAsName, Mode=OneWay}"/><Run Text="&quot; already exists. Overwrite it?"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="No" Command="{Binding CancelOverwriteSaveAsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Yes, overwrite" Command="{Binding ConfirmOverwriteSaveAsCommand}"
                                Background="#f9e2af"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Rename Saved Game Prompt (global overlay) -->
        <Grid Visibility="{Binding ShowRenameSavedGamePrompt, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="100">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="30"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="420" BorderBrush="#45475a" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Rename Saved Game" FontSize="{Binding XXLargeFontSize}" FontWeight="Bold"
                               Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="New Name" Foreground="#cdd6f4" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding RenameSavedGameName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="{Binding BaseFontSize}"
                             Padding="8,6" Background="#1e1e2e" Foreground="#cdd6f4"
                             BorderBrush="#585b70" BorderThickness="1">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding ConfirmRenameSavedGameCommand}"/>
                            <KeyBinding Key="Escape" Command="{Binding CancelRenameSavedGameCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <TextBlock Text="{Binding RenameSavedGameError}" Foreground="#f38ba8"
                               Visibility="{Binding HasRenameSavedGameError, Converter={StaticResource BoolToVis}}"
                               TextWrapping="Wrap" Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Content="Cancel" Command="{Binding CancelRenameSavedGameCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Rename" Command="{Binding ConfirmRenameSavedGameCommand}"
                                Background="#a6e3a1"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Load Game Picker Popup (global overlay) -->
        <Grid Visibility="{Binding ShowLoadGamePicker, Converter={StaticResource BoolToVis}}">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="30" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="650" MaxWidth="900" MaxHeight="800"
                    BorderBrush="#45475a" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Load Game" FontSize="{Binding XXLargeFontSize}" FontWeight="Bold" 
                               Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Grid.Row="1" Text="Select a saved game to continue:" 
                               Foreground="#a6adc8" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SavedGames}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Main save game button -->
                                        <Button Grid.Column="0"
                                                Command="{Binding DataContext.SelectSavedGameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="15,12"
                                                HorizontalContentAlignment="Left">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#45475a"/>
                                                    <Setter Property="Foreground" Value="#cdd6f4"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="#1e1e2e"/>
                                                            <Setter Property="Background" Value="#89b4fa"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" 
                                                           FontSize="{Binding DataContext.LargeFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <TextBlock Text="{Binding RoundInfo}" 
                                                               FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    <TextBlock Text=" • " 
                                                               FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    <TextBlock Text="{Binding SavedAtDisplay}" 
                                                               FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Button>
                                        
                                        <!-- Ellipsis menu button (visually attached to row) -->
                                        <Button x:Name="SaveMenuButton" Grid.Column="1" Content="⋯" 
                                                Command="{Binding DataContext.ToggleSaveDeleteMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                FontSize="20" FontWeight="Bold"
                                                Padding="12,0" Margin="0"
                                                VerticalAlignment="Stretch"
                                                ToolTip="More options">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#45475a"/>
                                                    <Setter Property="Foreground" Value="#a6adc8"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#585b70"/>
                                                            <Setter Property="Foreground" Value="#cdd6f4"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Dropdown popup with Delete action -->
                                        <Popup PlacementTarget="{Binding ElementName=SaveMenuButton}" Placement="Bottom"
                                               IsOpen="{Binding IsShowingDeleteOption}"
                                               StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade"
                                               HorizontalOffset="-4" VerticalOffset="2">
                                            <Border Background="#1e1e2e" BorderBrush="#45475a" BorderThickness="1" CornerRadius="6" Padding="4">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                                </Border.Effect>
                                                <StackPanel>
                                                    <Button Content="Rename"
                                                            Command="{Binding DataContext.BeginRenameSavedGameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            FontWeight="Bold" Padding="20,8" MinWidth="120"
                                                            Margin="0,0,0,4"
                                                            Cursor="Hand">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="#89b4fa"/>
                                                                <Setter Property="Foreground" Value="#1e1e2e"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#74c7ec"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <Button Content="Delete"
                                                        Command="{Binding DataContext.DeleteSavedGameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        FontWeight="Bold" Padding="20,8" MinWidth="120"
                                                        Cursor="Hand">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#f38ba8"/>
                                                            <Setter Property="Foreground" Value="#1e1e2e"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#eba0ac"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                </StackPanel>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <Button Grid.Row="3" Content="Cancel" Command="{Binding CancelLoadGameCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,15,0,0" HorizontalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Save Confirmation Popup (global overlay) -->
        <Grid Visibility="{Binding ShowSaveConfirmation, Converter={StaticResource BoolToVis}}">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="30" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="300"
                    BorderBrush="#45475a" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="✓" FontSize="48" FontWeight="Bold" 
                               Foreground="#a6e3a1" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Game successfully saved" FontSize="{Binding LargeFontSize}" FontWeight="Bold" 
                               Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <Button Content="OK" Command="{Binding DismissSaveConfirmationCommand}"
                            Background="#a6e3a1" Foreground="#1e1e2e" FontWeight="Bold"
                            Padding="30,10" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- New Game Confirmation Popup (global overlay) -->
        <Grid Visibility="{Binding ShowNewGameConfirm, Converter={StaticResource BoolToVis}}">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="30" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="350"
                    BorderBrush="#45475a" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="New Game?" FontSize="{Binding XXLargeFontSize}" FontWeight="Bold" 
                               Foreground="#f38ba8" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="Are you sure? Unsaved progress will be lost." 
                               Foreground="#cdd6f4" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Yes, New Game" Command="{Binding ConfirmNewGameCommand}"
                                Background="#f38ba8" Foreground="#1e1e2e" FontWeight="Bold"
                                Padding="20,10" Margin="0,0,15,0"/>
                        <Button Content="Cancel" Command="{Binding CancelNewGameCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Settings Changed New Game Prompt (global overlay) -->
        <Grid Visibility="{Binding ShowSettingsNewGamePrompt, Converter={StaticResource BoolToVis}}">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="30" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="400"
                    BorderBrush="#45475a" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Settings Changed" FontSize="{Binding XXLargeFontSize}" FontWeight="Bold" 
                               Foreground="#f9e2af" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="You've changed game settings that affect scoring. Would you like to start a new game with these settings?" 
                               Foreground="#cdd6f4" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,10" MaxWidth="350"/>
                    <TextBlock Text="Your current game will not be affected if you continue." 
                               Foreground="#a6adc8" FontSize="{Binding SmallFontSize}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Start New Game" Command="{Binding ConfirmSettingsNewGameCommand}"
                                Background="#a6e3a1" Foreground="#1e1e2e" FontWeight="Bold"
                                Padding="20,10" Margin="0,0,15,0"/>
                        <Button Content="Continue Current" Command="{Binding CancelSettingsNewGameCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Discard Settings Changes Prompt (global overlay) -->
        <Grid Visibility="{Binding ShowDiscardSettingsPrompt, Converter={StaticResource BoolToVis}}">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="30"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="400"
                    BorderBrush="#45475a" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Discard Changes?" FontSize="{Binding XXLargeFontSize}" FontWeight="Bold"
                               Foreground="#f9e2af" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="Are you sure you want to close? Unsaved changes will be lost."
                               Foreground="#cdd6f4" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20" MaxWidth="350"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Yes" Command="{Binding ConfirmDiscardSettingsCommand}"
                                Background="#f38ba8" Foreground="#1e1e2e" FontWeight="Bold"
                                Padding="20,10" Margin="0,0,15,0"/>
                        <Button Content="No" Command="{Binding CancelDiscardSettingsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Edit Chooser Popup (global overlay) -->
        <Grid Visibility="{Binding IsEditChooserOpen, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="120">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="30"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="420" MaxWidth="600"
                    BorderBrush="#45475a" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Edit Hand" FontSize="{Binding HugeFontSize}" FontWeight="Bold"
                               Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding EditingGameDescription}" FontSize="{Binding LargeFontSize}"
                               Foreground="#a6adc8" HorizontalAlignment="Center" Margin="0,0,0,20"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="Choose what to edit:" Foreground="#cdd6f4"
                               HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch">
                        <Button Content="Edit Inputs" Command="{Binding EditInputsCommand}"
                                Background="#89b4fa" Foreground="#1e1e2e" FontWeight="Bold"
                                Padding="20,10" Margin="0,0,0,10" Cursor="Hand"
                                HorizontalAlignment="Stretch"/>
                        <Button Content="Edit Final Score" Command="{Binding EditFinalScoreCommand}"
                                Background="#a6e3a1" Foreground="#1e1e2e" FontWeight="Bold"
                                Padding="20,10" Margin="0,0,0,10" Cursor="Hand"
                                HorizontalAlignment="Stretch"/>
                        <Button Content="Cancel" Command="{Binding CancelEditChooserCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Edit Bid Popup (Phase 4) -->
        <Grid Visibility="{Binding IsEditingBid, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="115" Grid.IsSharedSizeScope="True">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="20"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="700" MaxWidth="1000"
                    BorderBrush="#45475a" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Edit Bid" FontSize="{Binding HugeFontSize}" FontWeight="Bold"
                                   Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding EditingGameDescription}" FontSize="{Binding LargeFontSize}"
                                   Foreground="#a6adc8" HorizontalAlignment="Center" Margin="0,0,0,15"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                            <!-- Header row -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="EditBidLabel"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding EditDoublingMatrixHeaders}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1f3a5f" Margin="6,0" Padding="8,10">
                                                <TextBlock Text="{Binding Label}" Foreground="White" FontWeight="Bold"
                                                           FontSize="{Binding DataContext.LargeFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           HorizontalAlignment="Stretch" TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding Label}"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <!-- Matrix rows -->
                            <ItemsControl ItemsSource="{Binding EditDoublingMatrix}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="EditBidLabel"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#313244" Padding="10,12" Margin="0,0,2,0">
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DoublerLabel}" Foreground="#cdd6f4"
                                                               FontWeight="SemiBold"
                                                               FontSize="{Binding DataContext.LargeFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    <Border Background="#1f3a5f" CornerRadius="4" Padding="6,2"
                                                            HorizontalAlignment="Left" Margin="0,4,0,0"
                                                            Visibility="{Binding IsDealer, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="Dealer" Foreground="White" FontWeight="Bold"
                                                                   FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#3a3a52" Margin="6,0" Padding="6,8">
                                                            <Grid>
                                                                <TextBlock Text="—" Foreground="#585b70" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           FontSize="{Binding DataContext.LargeFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                            Visibility="{Binding IsNotEmpty, Converter={StaticResource BoolToVis}}">
                                                                    <StackPanel Orientation="Vertical" VerticalAlignment="Top" Margin="0,0,18,0"
                                                                                Visibility="{Binding IsDoubleVisible, Converter={StaticResource BoolToVis}}">
                                                                        <CheckBox Style="{StaticResource BidCheckBoxStyle}"
                                                                                  IsChecked="{Binding IsDouble, Mode=TwoWay}"
                                                                                  IsEnabled="{Binding IsDoubleEnabled}" ToolTip="Double">
                                                                            <CheckBox.LayoutTransform><ScaleTransform ScaleX="2.2" ScaleY="2.2"/></CheckBox.LayoutTransform>
                                                                        </CheckBox>
                                                                        <TextBlock Text="Dbl" Foreground="#a6adc8" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                                                   FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                                                                        <CheckBox Style="{StaticResource BidCheckBoxStyle}"
                                                                                  IsChecked="{Binding EffectiveRedouble, Mode=TwoWay}"
                                                                                  IsEnabled="{Binding IsRedoubleEnabled}"
                                                                                  ToolTip="Redouble (enabled after Dbl is checked)">
                                                                            <CheckBox.LayoutTransform><ScaleTransform ScaleX="2.2" ScaleY="2.2"/></CheckBox.LayoutTransform>
                                                                        </CheckBox>
                                                                        <TextBlock Text="Re-Dbl" Foreground="#a6adc8" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                                                   FontSize="{Binding DataContext.SmallFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    <TextBlock Grid.Row="2" Text="{Binding EditBidError}" Foreground="#f38ba8"
                               TextWrapping="Wrap" Margin="0,8,0,0" TextAlignment="Center"
                               Visibility="{Binding HasEditBidError, Converter={StaticResource BoolToVis}}"/>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Button Content="Continue" Command="{Binding ConfirmEditBidCommand}"
                                Background="#a6e3a1" Foreground="#1e1e2e" FontWeight="Bold"
                                Padding="20,10" Margin="0,0,15,0" Cursor="Hand"/>
                        <Button Content="Cancel" Command="{Binding CancelEditBidCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Edit Inputs Popup (Phase 3, contract-aware) -->
        <Grid Visibility="{Binding IsEditingInputs, Converter={StaticResource BoolToVis}}"
              x:Name="EditInputsPopup" IsVisibleChanged="EditInputsPopup_IsVisibleChanged"
              Panel.ZIndex="115">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="20"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="600" MaxWidth="780" MaxHeight="700"
                    BorderBrush="#45475a" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Edit Inputs" FontSize="{Binding HugeFontSize}" FontWeight="Bold"
                                   Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding EditingGameDescription}" FontSize="{Binding LargeFontSize}"
                                   Foreground="#a6adc8" HorizontalAlignment="Center" Margin="0,0,0,15"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Pickers first (matches original input flow): Ace -> King -> Last -> 2nd-to-last -->

                            <!-- Ace of Hearts picker (Hearts non-Salade) -->
                            <StackPanel Visibility="{Binding EditShowAcePicker, Converter={StaticResource BoolToVis}}" Margin="0,0,0,15">
                                <TextBlock Text="Player who won the Ace of Hearts:" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Players}" SelectedItem="{Binding EditAceOfHeartsPlayer}"
                                          DisplayMemberPath="DisplayName" MinWidth="260" HorizontalAlignment="Left"
                                          Background="#e6e9ef" Foreground="#1e1e2e"/>
                            </StackPanel>

                            <!-- King of Hearts picker (Barbu / Salade) -->
                            <StackPanel Visibility="{Binding EditShowKingPicker, Converter={StaticResource BoolToVis}}" Margin="0,0,0,15">
                                <TextBlock Text="Player who won the King of Hearts:" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Players}" SelectedItem="{Binding EditKingOfHeartsPlayer}"
                                          DisplayMemberPath="DisplayName" MinWidth="260" HorizontalAlignment="Left"
                                          Background="#e6e9ef" Foreground="#1e1e2e"/>
                            </StackPanel>

                            <!-- 2nd to last trick picker (NoLastTwo only, non-Salade) -->
                            <StackPanel Visibility="{Binding EditShowSecondToLastPicker, Converter={StaticResource BoolToVis}}" Margin="0,0,0,15">
                                <TextBlock Text="Player who won the 2nd to last trick:" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Players}" SelectedItem="{Binding EditSecondToLastTrickPlayer}"
                                          DisplayMemberPath="DisplayName" MinWidth="260" HorizontalAlignment="Left"
                                          Background="#e6e9ef" Foreground="#1e1e2e"/>
                            </StackPanel>

                            <!-- Last trick picker (NoLastTwo / Salade) -->
                            <StackPanel Visibility="{Binding EditShowLastPicker, Converter={StaticResource BoolToVis}}" Margin="0,0,0,15">
                                <TextBlock Text="Player who won the last trick:" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Players}" SelectedItem="{Binding EditLastTrickPlayer}"
                                          DisplayMemberPath="DisplayName" MinWidth="260" HorizontalAlignment="Left"
                                          Background="#e6e9ef" Foreground="#1e1e2e"/>
                            </StackPanel>

                            <!-- Numeric 4-input panel: Nullo / NoQueens / Hearts / Trumps / FanTan -->
                            <StackPanel Visibility="{Binding EditShowNumericFour, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,15">
                                <TextBlock Text="{Binding EditNumericLabel}" FontWeight="SemiBold"
                                           Foreground="#cdd6f4" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Players[0].DisplayName}" HorizontalAlignment="Stretch" TextAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="#cdd6f4" Margin="10,0,10,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Players[1].DisplayName}" HorizontalAlignment="Stretch" TextAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="#cdd6f4" Margin="10,0,10,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Players[2].DisplayName}" HorizontalAlignment="Stretch" TextAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="#cdd6f4" Margin="10,0,10,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Players[3].DisplayName}" HorizontalAlignment="Stretch" TextAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="#cdd6f4" Margin="10,0,10,5"/>
                                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="EditNum0" Width="80" TextAlignment="Center" Padding="6,4" Margin="6,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="EditNum1" Width="80" TextAlignment="Center" Padding="6,4" Margin="6,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="EditNum2" Width="80" TextAlignment="Center" Padding="6,4" Margin="6,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" x:Name="EditNum3" Width="80" TextAlignment="Center" Padding="6,4" Margin="6,0"/>
                                </Grid>
                                <TextBlock Visibility="{Binding EditShowFanTanHelp, Converter={StaticResource BoolToVis}}"
                                           Text="Enter 1 for first to go out, 2 for second, 3 for third, 4 for last."
                                           Foreground="#a6adc8" FontStyle="Italic" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Salade tricks/queens/hearts grid -->
                            <StackPanel Visibility="{Binding EditShowSaladeGrid, Converter={StaticResource BoolToVis}}" Margin="0,0,0,15">
                                <TextBlock Text="Salade: enter tricks, queens, and hearts per player" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,8"/>
                                <Grid KeyboardNavigation.TabNavigation="Local">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Player" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,10,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Tricks" FontWeight="Bold" Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Queens" FontWeight="Bold" Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Hearts" FontWeight="Bold" Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Players[0].DisplayName}" Foreground="#cdd6f4" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="EditSalT0" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="1"/>
                                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="EditSalQ0" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="5"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" x:Name="EditSalH0" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="9"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Players[1].DisplayName}" Foreground="#cdd6f4" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="EditSalT1" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="2"/>
                                    <TextBox Grid.Row="2" Grid.Column="2" x:Name="EditSalQ1" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="6"/>
                                    <TextBox Grid.Row="2" Grid.Column="3" x:Name="EditSalH1" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="10"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding Players[2].DisplayName}" Foreground="#cdd6f4" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="EditSalT2" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="3"/>
                                    <TextBox Grid.Row="3" Grid.Column="2" x:Name="EditSalQ2" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="7"/>
                                    <TextBox Grid.Row="3" Grid.Column="3" x:Name="EditSalH2" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="11"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding Players[3].DisplayName}" Foreground="#cdd6f4" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="EditSalT3" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="4"/>
                                    <TextBox Grid.Row="4" Grid.Column="2" x:Name="EditSalQ3" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="8"/>
                                    <TextBox Grid.Row="4" Grid.Column="3" x:Name="EditSalH3" Width="60" TextAlignment="Center" Margin="5,2" TabIndex="12"/>
                                </Grid>
                                <TextBlock Text="Tricks must total 13, queens 4, hearts 13." Foreground="#a6adc8" FontStyle="Italic" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- Ravage City selector -->
                            <StackPanel Visibility="{Binding EditShowRavageCity, Converter={StaticResource BoolToVis}}" Margin="0,0,0,15">
                                <TextBlock Text="Player(s) who took the most cards in any suit:" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding RavageCityScoringDescription}" Foreground="#a6adc8" FontStyle="Italic" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding EditRavageCitySelections}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,3,0,3">
                                                <TextBlock Text="{Binding Player.DisplayName}" Foreground="#cdd6f4"/>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Chinese Poker editor -->
                            <StackPanel Visibility="{Binding EditShowChinesePoker, Converter={StaticResource BoolToVis}}" Margin="0,0,0,15">
                                <TextBlock Text="Chinese Poker beats (+4 per beat)" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <RadioButton Content="By Setting (F/M/B)" IsChecked="{Binding EditChinesePokerScoreBySetting, Mode=TwoWay}" Margin="0,0,20,0" Foreground="#cdd6f4"/>
                                    <RadioButton Content="By Total Beats" IsChecked="{Binding EditChinesePokerScoreByTotal, Mode=TwoWay}" Foreground="#cdd6f4"/>
                                </StackPanel>
                                <Grid Visibility="{Binding EditChinesePokerScoreBySetting, Converter={StaticResource BoolToVis}}"
                                      KeyboardNavigation.TabNavigation="Local">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Player" FontWeight="Bold" Foreground="#cdd6f4" Margin="0,0,10,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Front" FontWeight="Bold" Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Middle" FontWeight="Bold" Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Back" FontWeight="Bold" Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Players[0].DisplayName}" Foreground="#cdd6f4" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="EditCP00" TabIndex="1" Width="50" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="EditCP01" TabIndex="5" Width="50" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" x:Name="EditCP02" TabIndex="9" Width="50" TextAlignment="Center" Margin="5,2"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Players[1].DisplayName}" Foreground="#cdd6f4" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="EditCP10" TabIndex="2" Width="50" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="2" Grid.Column="2" x:Name="EditCP11" TabIndex="6" Width="50" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="2" Grid.Column="3" x:Name="EditCP12" TabIndex="10" Width="50" TextAlignment="Center" Margin="5,2"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding Players[2].DisplayName}" Foreground="#cdd6f4" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="EditCP20" TabIndex="3" Width="50" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="3" Grid.Column="2" x:Name="EditCP21" TabIndex="7" Width="50" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="3" Grid.Column="3" x:Name="EditCP22" TabIndex="11" Width="50" TextAlignment="Center" Margin="5,2"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding Players[3].DisplayName}" Foreground="#cdd6f4" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="EditCP30" TabIndex="4" Width="50" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="4" Grid.Column="2" x:Name="EditCP31" TabIndex="8" Width="50" TextAlignment="Center" Margin="5,2"/>
                                    <TextBox Grid.Row="4" Grid.Column="3" x:Name="EditCP32" TabIndex="12" Width="50" TextAlignment="Center" Margin="5,2"/>
                                </Grid>
                                <Grid Visibility="{Binding EditChinesePokerScoreByTotal, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Players[0].DisplayName}" Foreground="#cdd6f4" HorizontalAlignment="Stretch" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="10,0,10,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Players[1].DisplayName}" Foreground="#cdd6f4" HorizontalAlignment="Stretch" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="10,0,10,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Players[2].DisplayName}" Foreground="#cdd6f4" HorizontalAlignment="Stretch" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="10,0,10,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Players[3].DisplayName}" Foreground="#cdd6f4" HorizontalAlignment="Stretch" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="10,0,10,5"/>
                                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="EditCPTot0" Width="60" TextAlignment="Center" Margin="6,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="EditCPTot1" Width="60" TextAlignment="Center" Margin="6,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="EditCPTot2" Width="60" TextAlignment="Center" Margin="6,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" x:Name="EditCPTot3" Width="60" TextAlignment="Center" Margin="6,0"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <TextBlock Grid.Row="2" Text="{Binding EditInputsError}" Foreground="#f38ba8"
                               TextWrapping="Wrap" Margin="0,8,0,0" TextAlignment="Center"
                               Visibility="{Binding HasEditInputsError, Converter={StaticResource BoolToVis}}"/>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Button Content="Back" Command="{Binding BackToEditBidCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,15,0"/>
                        <Button Content="Save" Click="EditInputsSave_Click"
                                Background="#a6e3a1" Foreground="#1e1e2e" FontWeight="Bold"
                                Padding="20,10" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Edit Score Popup (global overlay) -->
        <Grid Visibility="{Binding IsEditingScore, Converter={StaticResource BoolToVis}}"
              x:Name="EditScorePopup" IsVisibleChanged="EditScorePopup_IsVisibleChanged">
            <Border Background="#80000000"/>
            <Border Background="#313244" CornerRadius="12" Padding="30" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="400" MaxWidth="600"
                    BorderBrush="#45475a" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Edit Score" FontSize="{Binding HugeFontSize}" FontWeight="Bold" 
                               Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding EditingGameDescription}" FontSize="{Binding LargeFontSize}" 
                               Foreground="#a6adc8" HorizontalAlignment="Center" Margin="0,0,0,20"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                    
                    <!-- Score Entry Grid -->
                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Player Names -->
                        <TextBlock Grid.Column="0" Grid.Row="0" Text="{Binding Players[0].Name}" 
                                   Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="10,0,10,5"/>
                        <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding Players[1].Name}" 
                                   Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="10,0,10,5"/>
                        <TextBlock Grid.Column="2" Grid.Row="0" Text="{Binding Players[2].Name}" 
                                   Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="10,0,10,5"/>
                        <TextBlock Grid.Column="3" Grid.Row="0" Text="{Binding Players[3].Name}" 
                                   Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="10,0,10,5"/>
                        
                        <!-- Score Inputs -->
                        <TextBox Grid.Column="0" Grid.Row="1" x:Name="EditInput1" Width="70" 
                                 Background="#45475a" Foreground="#cdd6f4" FontSize="{Binding LargeFontSize}"
                                 TextAlignment="Center" Padding="5" Margin="10,0"/>
                        <TextBox Grid.Column="1" Grid.Row="1" x:Name="EditInput2" Width="70" 
                                 Background="#45475a" Foreground="#cdd6f4" FontSize="{Binding LargeFontSize}"
                                 TextAlignment="Center" Padding="5" Margin="10,0"/>
                        <TextBox Grid.Column="2" Grid.Row="1" x:Name="EditInput3" Width="70" 
                                 Background="#45475a" Foreground="#cdd6f4" FontSize="{Binding LargeFontSize}"
                                 TextAlignment="Center" Padding="5" Margin="10,0"/>
                        <TextBox Grid.Column="3" Grid.Row="1" x:Name="EditInput4" Width="70" 
                                 Background="#45475a" Foreground="#cdd6f4" FontSize="{Binding LargeFontSize}"
                                 TextAlignment="Center" Padding="5" Margin="10,0"/>
                    </Grid>
                    
                    <!-- Error Message -->
                    <TextBlock Text="{Binding EditErrorMessage}" Foreground="#f38ba8" 
                               TextAlignment="Center" Margin="0,15,0,0"
                               Visibility="{Binding HasEditError, Converter={StaticResource BoolToVis}}"
                               TextWrapping="Wrap"/>
                    
                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="Confirm" Click="EditScore_Click"
                                Background="#a6e3a1" Foreground="#1e1e2e" FontWeight="Bold"
                                Padding="20,10" Margin="0,0,15,0" Cursor="Hand"/>
                        <Button Content="Cancel" Command="{Binding CancelEditScoreCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Save toast (top-left, auto-dismisses) -->
        <Border Background="#1e1e2e" BorderBrush="#a6e3a1" BorderThickness="1" CornerRadius="6"
                Padding="14,8" HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="20,20,0,0"
                Visibility="{Binding ShowSaveToast, Converter={StaticResource BoolToVis}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x2714;" Foreground="#a6e3a1" FontWeight="Bold" VerticalAlignment="Center"
                           FontSize="{Binding BaseFontSize}"/>
                <TextBlock Text="Game saved" Foreground="#cdd6f4" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"
                           FontSize="{Binding BaseFontSize}"/>
            </StackPanel>
        </Border>

        <!-- Load toast (top-left, auto-dismisses) -->
        <Border Background="#1e1e2e" BorderBrush="#a6e3a1" BorderThickness="1" CornerRadius="6"
                Padding="14,8" HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="20,20,0,0"
                Visibility="{Binding ShowLoadToast, Converter={StaticResource BoolToVis}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x2714;" Foreground="#a6e3a1" FontWeight="Bold" VerticalAlignment="Center"
                           FontSize="{Binding BaseFontSize}"/>
                <TextBlock Text="Game loaded" Foreground="#cdd6f4" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"
                           FontSize="{Binding BaseFontSize}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

